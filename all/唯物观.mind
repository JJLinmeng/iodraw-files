{"root":{"data":{"text":"马克思主义哲学"},"children":[{"data":{"text":"唯物论","layout":null},"children":[{"data":{"text":"（一）五观","layout":null},"children":[{"data":{"text":"物质观","layout":null},"children":[{"data":{"text":"概念","layout":null},"children":[{"data":{"text":"客观实在","expandState":"expand","layout":null},"children":[{"data":{"text":"不依赖于人的感觉而存在","layout":null},"children":[]},{"data":{"text":"为人的感觉所反映（能动反映）","layout":null},"children":[]}]}]},{"data":{"text":"特征","layout":null},"children":[{"data":{"text":"客观实在性：物质的共同特性、唯一共性","layout":null},"children":[]}]},{"data":{"text":"关系","layout":null},"children":[{"data":{"text":"不同阶段唯物主义对物质概念的看法","expandState":"expand","layout":null},"children":[{"data":{"text":"古代朴素唯物主义：归结为一种或几种具体物质形态（金、木、水、火、气）","layout":null},"children":[]},{"data":{"text":"近代形而上学唯物主义：归结为最小单位 —— 原子","layout":null},"children":[]},{"data":{"text":"现代辩证唯物主义","layout":null},"children":[]}]},{"data":{"text":"哲学物质范畴与自然科学物质概念的关系：共性与个性","layout":null},"children":[]}]},{"data":{"text":"（4）方法论","layout":null},"children":[{"data":{"text":"坚持唯物主义一元论","layout":null},"children":[]},{"data":{"text":"坚持能动反映论和可知论","layout":null},"children":[]},{"data":{"text":"体现唯物论与辩证法的统一","layout":null},"children":[]},{"data":{"text":"体现唯物主义自然观与历史观的统一","layout":null},"children":[]}]}]},{"data":{"text":"运动观","layout":null},"children":[{"data":{"text":"概念","layout":null},"children":[{"data":{"text":"一切事物和现象","layout":null},"children":[]},{"data":{"text":"变化及过程","layout":null},"children":[]}]},{"data":{"text":"特性","layout":null},"children":[{"data":{"text":"客观实在性","layout":null},"children":[]}]},{"data":{"text":"关系","layout":null},"children":[{"data":{"text":"运动和物质的关系","expandState":"expand","layout":null},"children":[{"data":{"text":"二者不可分割（离开物质谈运动犯唯心主义错误）","layout":null},"children":[]},{"data":{"text":"运动是物质的根本属性","layout":null},"children":[]}]},{"data":{"text":"运动和静止的关系","expandState":"expand","layout":null},"children":[{"data":{"text":"静止","expandState":"expand","layout":null},"children":[{"data":{"text":"是物质运动的特殊状态","layout":null},"children":[]},{"data":{"text":"在一定条件下保持稳定","layout":null},"children":[]},{"data":{"text":"包含两种状态：空间位置不变、根本性质不变","layout":null},"children":[]}]},{"data":{"text":"关系","expandState":"expand","layout":null},"children":[{"data":{"text":"不可分割","layout":null},"children":[]},{"data":{"text":"相互渗透","layout":null},"children":[]},{"data":{"text":"无条件的绝对运动 + 有条件的相对静止，共同构成矛盾运动","layout":null},"children":[]}]}]}]},{"data":{"id":"djoxvtns2lc0","created":1783082189751,"text":"方法论","layout":null},"children":[{"data":{"id":"djoxvx3mk800","created":1783082197239,"text":"一切以具体时间、地点、条件的转移而转移","layout":null},"children":[]}]}]},{"data":{"text":"时空观","expandState":"expand","layout":null},"children":[{"data":{"text":"概念","layout":null},"children":[{"data":{"text":"时间：物质运动的持续性、顺序性","layout":null},"children":[]},{"data":{"text":"空间：物质运动的广延性、伸张性","layout":null},"children":[]}]},{"data":{"text":"特征","layout":null},"children":[{"data":{"text":"时间：一维性（一去不复返）、客观性","layout":null},"children":[]},{"data":{"text":"空间：三维性（长宽高）、客观性","layout":null},"children":[]}]},{"data":{"text":"关系","layout":null},"children":[{"data":{"text":"时空与物质运动的关系","expandState":"expand","layout":null},"children":[{"data":{"text":"二者不可分割","layout":null},"children":[]},{"data":{"text":"时空是物质运动的基本存在方式","layout":null},"children":[]}]},{"data":{"text":"时空的特性","expandState":"expand","layout":null},"children":[{"data":{"text":"具体物质形态的时空是有限的","layout":null},"children":[]},{"data":{"text":"整个物质世界的时空是无限的","layout":null},"children":[]}]}]},{"data":{"text":"方法论","layout":null},"children":[{"data":{"text":"一切以具体时间、地点、条件的转移而转移","layout":null},"children":[]}]}]},{"data":{"text":"实践观","layout":null},"children":[{"data":{"text":"核心逻辑：实践活动导致世界二重化","layout":null},"children":[{"data":{"text":"世界划分","expandState":"expand","layout":null},"children":[{"data":{"text":"客观世界（物质世界）：自然界、人类社会","layout":null},"children":[]},{"data":{"text":"主观世界（精神世界）：思维领域","layout":null},"children":[]}]},{"data":{"text":"自然界分化出人类社会","layout":null},"children":[]},{"data":{"text":"客观世界分化出主观世界","layout":null},"children":[]}]},{"data":{"text":"核心结论","layout":null},"children":[{"data":{"text":"人的实践活动是自然与社会、客观与主观分化又统一的关键","layout":null},"children":[]}]}]},{"data":{"text":"意识观","layout":null},"children":[{"data":{"text":"物质决定意识","layout":null},"children":[{"data":{"text":"意识的起源","expandState":"expand","layout":null},"children":[{"data":{"text":"是自然界长期发展的产物（三阶段）","expandState":"expand","layout":null},"children":[{"data":{"text":"低等生物：刺激感应性","layout":null},"children":[]},{"data":{"text":"高等动物：感觉和心理","layout":null},"children":[]},{"data":{"text":"人类：意识","layout":null},"children":[]}]},{"data":{"text":"是社会历史发展的产物","expandState":"expand","layout":null},"children":[{"data":{"text":"实践 / 劳动：对意识产生起决定性作用","layout":null},"children":[]},{"data":{"text":"语言：对意识发展起促进作用","layout":null},"children":[]}]}]},{"data":{"text":"意识的本质","expandState":"expand","layout":null},"children":[{"data":{"text":"意识≠人脑，意识是人脑这一特殊物质的机能和属性","layout":null},"children":[]},{"data":{"text":"意识是客观世界的主观映象（主观反映客观）","layout":null},"children":[]},{"data":{"text":"是客观内容与主观形式的统一：内容客观、形式主观","layout":null},"children":[]},{"data":{"text":"意识≠物质，是物质的产物、意识是对也只能是对物质的反映、二者不能相互替代，但可以相互转化","layout":null},"children":[]}]}]},{"data":{"text":"意识反作用于物质（意识的能动作用）","layout":null},"children":[{"data":{"text":"任何意识都具有目的性和计划性","layout":null},"children":[]},{"data":{"text":"意识活动具有创造性","layout":null},"children":[]},{"data":{"text":"意识能够指导实践","layout":null},"children":[]},{"data":{"text":"意识能够调控人的行为和心理活动","layout":null},"children":[]},{"data":{"text":"特殊表现：人工智能","layout":null},"children":[]}]}]}]},{"data":{"text":"三原理","layout":null},"children":[{"data":{"text":"物质与意识的关系","layout":null},"children":[{"data":{"text":"物质决定意识","layout":null},"children":[]},{"data":{"text":"意识反作用于物质","layout":null},"children":[]}]},{"data":{"text":"主观能动性与客观规律的辩证关系","layout":null},"children":[{"data":{"text":"规律","layout":null},"children":[{"data":{"text":"概念","expandState":"expand","layout":null},"children":[{"data":{"text":"固有的","layout":null},"children":[]},{"data":{"text":"本质的、内在的、必然的、稳定的","layout":null},"children":[]}]},{"data":{"text":"分类","expandState":"expand","layout":null},"children":[{"data":{"text":"自然规律：自然界：自发、盲目的、无意识的","layout":null},"children":[]},{"data":{"text":"社会规律：人类社会：自觉、有目的的有意识的人发挥作用","layout":null},"children":[]}]},{"data":{"text":"对待规律的态度","expandState":"expand","layout":null},"children":[{"data":{"text":"可以发现、认识、利用规律","layout":null},"children":[]},{"data":{"text":"不能消灭、创造规律","layout":null},"children":[]}]}]},{"data":{"text":"二者关系","layout":null},"children":[{"data":{"text":"发挥主观能动性必须以尊重客观规律为前提","layout":null},"children":[]},{"data":{"text":"只有充分发挥主观能动性，才能认识和利用规律","layout":null},"children":[]}]}]},{"data":{"text":"世界的物质统一性原理","layout":null},"children":[{"data":{"text":"世界统一于物质，是多样性的统一","layout":null},"children":[]}]}]}]},{"data":{"text":"辩证法","layout":null},"children":[{"data":{"text":"两大观点","layout":null},"children":[{"data":{"text":"联系","expandState":"expand","layout":null},"children":[{"data":{"id":"djqi4uipg9c0","created":1783240879053,"text":"概念","layout":null},"children":[{"data":{"id":"djqi3ul9w7k0","created":1783240800844,"text":"事物之间、事物内部诸要素之间相互影响、相互制约、相互作用的关系。","layout":null},"children":[]}]},{"data":{"id":"djqi4uip9m80","created":1783240879053,"text":"特征","layout":null},"children":[{"data":{"id":"djqi2wzpiq00","created":1783240727706,"text":"客观性","layout":null},"children":[{"data":{"id":"djqi2wzp4u00","created":1783240727706,"text":"联系客观存在，事物本身固有，不以人的意志为转移。","layout":null},"children":[]},{"data":{"id":"djqi2wzpc4g0","created":1783240727706,"text":"方法论：认识事物要从事物所固有的联系出发。","layout":null},"children":[]}]},{"data":{"id":"djqi2x0182o0","created":1783240727726,"text":"普遍性","font-weight":"bold","layout":null},"children":[{"data":{"id":"djqi2x01eeo0","created":1783240727726,"text":"整个世界是一个普遍联系的有机整体。","layout":null},"children":[]},{"data":{"id":"djqi2x01a680","created":1783240727726,"text":"时时有联系，事事有联系，无处不在，无时不有。","layout":null},"children":[]},{"data":{"id":"djqi2x01zu80","created":1783240727727,"text":"方法论","layout":null},"children":[{"data":{"id":"djqi2x01ihk0","created":1783240727727,"text":"承认联系普遍存在","layout":null},"children":[]},{"data":{"id":"djqi2x01z8g0","created":1783240727727,"text":"具体联系具体分析","layout":null},"children":[]}]}]},{"data":{"id":"djqi2x0e3pc0","created":1783240727748,"text":"多样性","layout":null},"children":[{"data":{"id":"djqi2x0eaow0","created":1783240727748,"text":"内部和外部（相对）","layout":null},"children":[]},{"data":{"id":"djqi2x0e31k0","created":1783240727748,"text":"直接和间接（中介）","layout":null},"children":[]},{"data":{"id":"djqi2x0e2540","created":1783240727748,"text":"必然与偶然（趋势）","layout":null},"children":[]},{"data":{"id":"djqi2x0e8ps0","created":1783240727748,"text":"本质与非本质（根本性质）","layout":null},"children":[]}]},{"data":{"id":"djqi2x0rwi00","created":1783240727771,"text":"条件性","layout":null},"children":[{"data":{"id":"djqi2x0ry8g0","created":1783240727771,"text":"联系是有条件的，条件对事物有促进/制约作用。","layout":null},"children":[]},{"data":{"id":"djqi2x0s0k80","created":1783240727771,"text":"条件可以改变，但不是任意改变，必须符合客观规律。","layout":null},"children":[]},{"data":{"id":"djqi2x0ruc00","created":1783240727771,"text":"方法论","layout":null},"children":[{"data":{"id":"djqi2x0rxtk0","created":1783240727771,"text":"坚持唯物辩证法条件论，反对唯心主义无条件论和唯条件论","layout":null},"children":[]},{"data":{"id":"djqi2x0roi80","created":1783240727771,"text":"化不利条件为有利条件。","layout":null},"children":[]}]}]}]},{"data":{"id":"djqi4uiqmo80","created":1783240879055,"text":"关系：系统思维","layout":null},"children":[]},{"data":{"id":"djqi4uiqo1k0","created":1783240879055,"text":"方法论","layout":null},"children":[{"data":{"id":"djqi2wxqeko0","created":1783240727587,"text":"承认联系普遍存在。","layout":null},"children":[]},{"data":{"id":"djqi2wy58hk0","created":1783240727612,"text":"先分析事物具体联系，然后确立整体性、开放性原则，从动态中把握事物的普遍联系。","layout":null},"children":[]}]}]},{"data":{"text":"发展","expandState":"expand","layout":null},"children":[{"data":{"text":"概念","layout":null},"children":[{"data":{"id":"djqi5mf4bm80","created":1783240939786,"text":"前进、上升的运动。","layout":null},"children":[]}]},{"data":{"text":"实质：新事物产生，旧事物灭亡。","layout":null},"children":[{"data":{"text":"概念","layout":null},"children":[{"data":{"id":"djqi2wuujco0","created":1783240727413,"text":"新事物：合乎历史发展方向，具有远大前途。","layout":null},"children":[]},{"data":{"id":"djqi2wv6ocg0","created":1783240727433,"text":"旧事物：丧失历史必然性，日趋灭亡。","layout":null},"children":[]}]},{"data":{"text":"判断标准","layout":null},"children":[{"data":{"id":"djqi2wtruw00","created":1783240727348,"text":"不取决于时间先后和形式新旧","layout":null},"children":[]},{"data":{"id":"djqi2wu7h2g0","created":1783240727374,"text":"概念","layout":null},"children":[]}]},{"data":{"text":"新事物战胜旧事物的原因","layout":null},"children":[{"data":{"id":"djqi2wskmyg0","created":1783240727275,"text":"与环境的关系","layout":null},"children":[{"data":{"id":"djqi6glvgow0","created":1783241005498,"text":"具有强大生命力、本质的原因","layout":null},"children":[]}]},{"data":{"id":"djqi2wsvjbk0","created":1783240727293,"text":"与旧事物的关系","layout":null},"children":[{"data":{"id":"djqi6zrduxs0","created":1783241047190,"text":"具有强大生命力、本质的原因","layout":null},"children":[]}]},{"data":{"id":"djqi2wt66nk0","created":1783240727311,"text":"在社会历史领域","layout":null},"children":[]}]}]},{"data":{"text":"关系","layout":null},"children":[{"data":{"id":"djqi79d3deg0","created":1783241068094,"text":"过程论","expandState":"expand","layout":null},"children":[{"data":{"text":"整个世界是过程的集合体。","layout":null},"children":[]},{"data":{"text":"任何事物都是过程。","layout":null},"children":[]},{"data":{"id":"djqi2wrfig00","created":1783240727206,"text":"任何事物都有其产生、发展、消亡的过程。","layout":null},"children":[]},{"data":{"id":"djqi2wrpz6o0","created":1783240727223,"text":"任何事物都有其过去、现在、未来。","layout":null},"children":[]}]}]},{"data":{"text":"方法论","layout":null},"children":[{"data":{"id":"djqi2wpyz6o0","created":1783240727118,"text":"要用发展的眼光（历史的眼光）看问题。","layout":null},"children":[]},{"data":{"id":"djqi2wq9uxs0","created":1783240727136,"text":"了解过去，观察现在，展望未来。","layout":null},"children":[]}]}]}]},{"data":{"text":"三大规律","layout":null},"children":[{"data":{"text":"对立统一规律","layout":null,"expandState":"expand"},"children":[{"data":{"text":"1. 矛盾的同一性和斗争性","layout":null},"children":[{"data":{"text":"概念","layout":null},"children":[{"data":{"text":"同一性","layout":null},"children":[{"data":{"id":"djqi2wiq1z40","created":1783240726679,"text":"相互依存，相互依赖，互为前提，缺一不可，并处于同一个统一体中","layout":null},"children":[]},{"data":{"id":"djqi2wjeo4g0","created":1783240726721,"text":"相互贯通，在一定条件下相互转化。","layout":null},"children":[]}]},{"data":{"text":"斗争性：相互排斥，分为对抗性、非对抗性。","layout":null},"children":[]}]},{"data":{"text":"关系","layout":null},"children":[{"data":{"text":"相辅相成，相互联结，不可分割，缺一不可。","layout":null},"children":[]},{"data":{"text":"斗争性寓于同一性中，同一性通过斗争性来体现。","layout":null},"children":[]},{"data":{"text":"无条件的绝对的斗争性，有条件的相对的同一性，两者相结合构成矛盾运动，推动发展（动力）。","layout":null},"children":[]}]},{"data":{"text":"作用","layout":null},"children":[{"data":{"text":"同一性的作用","layout":null},"children":[{"data":{"id":"djqi2wctl0g0","created":1783240726323,"text":"是事物存在和发展的前提。","layout":null},"children":[]},{"data":{"id":"djqi2wd741s0","created":1783240726345,"text":"使矛盾双方相互吸收有利于自身因素，各自发展。","layout":null},"children":[]},{"data":{"id":"djqi2wdkfzk0","created":1783240726368,"text":"规定着事物转化的可能和趋势，有规律地向对立面转化。","layout":null},"children":[]}]},{"data":{"text":"斗争性的作用","layout":null},"children":[{"data":{"id":"djqi2wapd5s0","created":1783240726195,"text":"促使矛盾双方力量对比发生变化，没有改变统一体的性质（量变阶段）。","layout":null},"children":[]},{"data":{"id":"djqi2wb53mw0","created":1783240726221,"text":"使矛盾统一体向另一种矛盾统一体过渡的决定力量（质变阶段）。","layout":null},"children":[]},{"data":{"id":"djqi2wbibc80","created":1783240726243,"text":"规定着量变到质变。","layout":null},"children":[]},{"data":{"id":"djqi2wbx5480","created":1783240726269,"text":"二者共同发挥作用。","layout":null},"children":[]}]}]},{"data":{"id":"djqi2wk89ew0","created":1783240726770,"text":"方法论","layout":null},"children":[{"data":{"id":"djqi2wk7txk0","created":1783240726770,"text":"在对立中把握同一，在同一中把握对立。","layout":null},"children":[]},{"data":{"id":"djqi2wk83pk0","created":1783240726770,"text":"一分为二看问题。","layout":null},"children":[]}]}]},{"data":{"text":"2. 矛盾的普遍性和特殊性","layout":null},"children":[{"data":{"text":"概念","layout":null},"children":[{"data":{"id":"djqi2w8t10o0","created":1783240726080,"text":"普遍性","layout":null},"children":[{"data":{"id":"djqi9kym9b40","created":1783241250068,"text":"时时有矛盾，事事有矛盾，无处不在，无时不有。","layout":null},"children":[]}]},{"data":{"id":"djqi2w96zs00","created":1783240726103,"text":"特殊性","layout":null},"children":[{"data":{"id":"djqi2w96ob40","created":1783240726103,"text":"不同事物，其矛盾特点不同。","layout":null},"children":[]},{"data":{"id":"djqi2w978uw0","created":1783240726104,"text":"同一事物在不同发展阶段其矛盾特点不同。","layout":null},"children":[]},{"data":{"id":"djqi2w97mfc0","created":1783240726104,"text":"构成事物的诸多矛盾以及每一个矛盾的不同方面其地位、性质、作用不同。","layout":null},"children":[]}]}]},{"data":{"text":"关系","layout":null},"children":[{"data":{"id":"djqi2w6oc3c0","created":1783240725951,"text":"辩证统一，不可分割。","layout":null},"children":[]},{"data":{"id":"djqi2w71etk0","created":1783240725973,"text":"任何事物都是共性与个性的统一。","layout":null},"children":[]},{"data":{"id":"djqi2w7dj9c0","created":1783240725993,"text":"共性寓于个性之中。","layout":null},"children":[]},{"data":{"id":"djqi2w7q6dk0","created":1783240726014,"text":"矛盾问题精髓：共性与个性，绝对与相对。","layout":null},"children":[]},{"data":{"id":"djqi2w83e5k0","created":1783240726037,"text":"人的认识一般规律：个别 -> 一般 -> 个别。","layout":null},"children":[]}]},{"data":{"id":"djqi2w9wht40","created":1783240726146,"text":"方法论","layout":null},"children":[{"data":{"id":"djqi2w9x0ag0","created":1783240726147,"text":"承认矛盾普遍存在。","layout":null},"children":[]},{"data":{"id":"djqi2w9x3a00","created":1783240726147,"text":"具体问题具体分析。","layout":null},"children":[]}]}]},{"data":{"id":"djqi8gf4xvk0","created":1783241161819,"text":"3. 矛盾的不平衡性","layout":null},"children":[]}]},{"data":{"text":"质量互变规律","layout":null},"children":[]},{"data":{"text":"否定之否定规律","layout":null},"children":[]}]},{"data":{"text":"五大环节（范畴）","layout":null},"children":[{"data":{"text":"内容与形式","layout":null},"children":[]},{"data":{"text":"现象与本质","layout":null},"children":[]},{"data":{"text":"原因与结果","layout":null},"children":[]},{"data":{"text":"必然与偶然","layout":null},"children":[]},{"data":{"text":"可能与现实","layout":null},"children":[]}]},{"data":{"text":"六大思维能力","layout":null},"children":[{"data":{"id":"djqi2x3c8xs0","created":1783240727926,"text":"辩证思维","layout":null},"children":[]},{"data":{"id":"djqi2x3orgg0","created":1783240727947,"text":"历史思维","layout":null},"children":[]},{"data":{"id":"djqi2x3zb200","created":1783240727965,"text":"系统思维","layout":null},"children":[]},{"data":{"id":"djqi2x4a5jc0","created":1783240727983,"text":"战略思维","layout":null},"children":[]},{"data":{"id":"djqi2x4ll4o0","created":1783240728002,"text":"底线思维","layout":null},"children":[]},{"data":{"id":"djqi2x4w7vk0","created":1783240728020,"text":"创新思维","layout":null},"children":[]}]}]},{"data":{"text":"认识论","layout":null},"children":[]},{"data":{"text":"唯物史观","layout":null},"children":[]}]},"template":"right","theme":"fresh-blue","version":"1.4.43"}