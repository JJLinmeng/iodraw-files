{"root":{"data":{"text":"认识论"},"children":[{"data":{"text":"一、 认识的来源"},"children":[{"data":{"text":"1. 实践决定认识"},"children":[{"data":{"text":"实践"},"children":[{"data":{"text":"实践的概念"},"children":[{"data":{"text":"人类能动（主动、积极、创造性）改造世界的社会性的物质活动（客观性）"},"children":[{"data":{"text":"人的本质"},"children":[{"data":{"text":"一切社会关系的总和"},"children":[]}]},{"data":{"text":"人的本质属性"},"children":[{"data":{"text":"社会性"},"children":[]}]}]}]},{"data":{"text":"实践的特征"},"children":[{"data":{"text":"① 客观实在性"},"children":[{"data":{"id":"djsb29l5fkg0","created":1783424048904,"text":"把蓝图变现实"},"children":[]}]},{"data":{"text":"② 自觉能动性 / 意识的能动性"},"children":[{"data":{"id":"djsb25y0l8w0","created":1783424040975,"text":"主动积极创造性、把想象变成蓝图"},"children":[]}]},{"data":{"text":"③ 社会历史性"},"children":[{"data":{"id":"djsb2bedr6w0","created":1783424052848,"text":"受一定历史条件制约"},"children":[]}]}]},{"data":{"text":"实践的基本构成 (骨骼)"},"children":[{"data":{"text":"① 主体"},"children":[{"data":{"id":"djsb2ggweyo0","created":1783424063885,"text":"主体能力"},"children":[]},{"data":{"id":"djsb2izjdcw0","created":1783424069365,"text":"从事实践活动"},"children":[]}]},{"data":{"text":"② 客体"},"children":[{"data":{"id":"djsb2pjwmsg0","created":1783424083657,"text":"实践活动所指向的对象"},"children":[]},{"data":{"id":"djsb2qiqt8w0","created":1783424085764,"text":"客体不完全等于客观事物"},"children":[]}]},{"data":{"text":"③ 中介"},"children":[{"data":{"id":"djsb30e3jmo0","created":1783424107251,"text":"1"},"children":[{"data":{"id":"djsb33iuam00","created":1783424114068,"text":"工具手段"},"children":[]},{"data":{"id":"djsb33yz9co0","created":1783424115044,"text":"程序、方法"},"children":[]}]},{"data":{"id":"djsb315lzgw0","created":1783424108914,"text":"分类"},"children":[{"data":{"id":"djsb3gyz80o0","created":1783424143342,"text":"物质性工具系统"},"children":[]},{"data":{"id":"djsb3hgdrxk0","created":1783424144394,"text":"语言符号工具系统"},"children":[]}]}]}]},{"data":{"text":"关系","expandState":"expand"},"children":[{"data":{"text":"① 相互作用"},"children":[]},{"data":{"text":"② 实践的主客体 = 认识的主客体