{"root":{"data":{"text":"认识论"},"children":[{"data":{"text":"一、 认识的来源"},"children":[{"data":{"text":"1. 实践决定认识"},"children":[{"data":{"text":"实践"},"children":[{"data":{"text":"实践的概念"},"children":[{"data":{"text":"人类能动（主动、积极、创造性）改造世界的社会性的物质活动（客观性）"},"children":[{"data":{"text":"人的本质"},"children":[{"data":{"text":"一切社会关系的总和"},"children":[]}]},{"data":{"text":"人的本质属性"},"children":[{"data":{"text":"社会性"},"children":[]}]}]}]},{"data":{"text":"实践的特征"},"children":[{"data":{"text":"① 客观实在性"},"children":[{"data":{"id":"djsb29l5fkg0","created":1783424048904,"text":"把蓝图变现实"},"children":[]}]},{"data":{"text":"② 自觉能动性 / 意识的能动性"},"children":[{"data":{"id":"djsb25y0l8w0","created":1783424040975,"text":"主动积极创造性、把想象变成蓝图"},"children":[]}]},{"data":{"text":"③ 社会历史性"},"children":[{"data":{"id":"djsb2bedr6w0","created":1783424052848,"text":"受一定历史条件制约"},"children":[]}]}]},{"data":{"text":"实践的基本构成 (骨骼)"},"children":[{"data":{"text":"① 主体"},"children":[{"data":{"id":"djsb2ggweyo0","created":1783424063885,"text":"主体能力"},"children":[]},{"data":{"id":"djsb2izjdcw0","created":1783424069365,"text":"从事实践活动"},"children":[]}]},{"data":{"text":"② 客体"},"children":[{"data":{"id":"djsb2pjwmsg0","created":1783424083657,"text":"实践活动所指向的对象"},"children":[]},{"data":{"id":"djsb2qiqt8w0","created":1783424085764,"text":"客体不完全等于客观事物"},"children":[]}]},{"data":{"text":"③ 中介"},"children":[{"data":{"id":"djsb30e3jmo0","created":1783424107251,"text":"1"},"children":[{"data":{"id":"djsb33iuam00","created":1783424114068,"text":"工具手段"},"children":[]},{"data":{"id":"djsb33yz9co0","created":1783424115044,"text":"程序、方法"},"children":[]}]},{"data":{"id":"djsb315lzgw0","created":1783424108914,"text":"分类"},"children":[{"data":{"id":"djsb3gyz80o0","created":1783424143342,"text":"物质性工具系统"},"children":[]},{"data":{"id":"djsb3hgdrxk0","created":1783424144394,"text":"语言符号工具系统"},"children":[]}]}]}]},{"data":{"text":"关系","expandState":"expand"},"children":[{"data":{"text":"① 相互作用"},"children":[]},{"data":{"text":"② 实践的主客体 = 认识的主客体"},"children":[]},{"data":{"text":"③ 关系"},"children":[{"data":{"text":"实践关系（最根本）"},"children":[]},{"data":{"text":"认识和改造关系"},"children":[]},{"data":{"text":"价值关系"},"children":[]}]},{"data":{"text":"双向运动"},"children":[{"data":{"text":"主体客体化与客体主体化的双向运动（换位思考）"},"children":[]}]}]},{"data":{"text":"实践的基本形式"},"children":[{"data":{"text":"① 物质生产实践"},"children":[{"data":{"id":"djsb4fj76rs0","created":1783424218575,"text":"最基本 决定其他"},"children":[]}]},{"data":{"text":"② 社会政治实践"},"children":[]},{"data":{"text":"③ 科学文化实践"},"children":[]},{"data":{"text":"④ 关系"},"children":[{"data":{"text":"物质生产实践决定社会政治实践和科学文化实践"},"children":[]},{"data":{"text":"社会政治实践、科学文化实践又反作用于物质生产实践"},"children":[]}]},{"data":{"text":"⑤ 新的实践形式"},"children":[{"data":{"text":"虚拟实践（不是基本）"},"children":[]}]}]}]},{"data":{"text":"实践决定认识"},"children":[{"data":{"text":"① 来源"},"children":[]},{"data":{"text":"② 动力"},"children":[]},{"data":{"text":"③ 目的"},"children":[]},{"data":{"text":"④ 唯一标准"},"children":[]},{"data":{"text":"⑤ 出发点、落脚点、归宿"},"children":[]}]}]},{"data":{"text":"2. 认识反作用于实践"},"children":[{"data":{"text":"认识指导实践，特别是认识的高级形式理论对实践有巨大指导作用"},"children":[]}]}]},{"data":{"text":"二、 认识的本质"},"children":[{"data":{"text":"1. 不同学派对认识本质的不同回答 两种根本对立的认识路线"},"children":[{"data":{"text":"① 唯心主义（先验论）"},"children":[{"data":{"text":"主观唯心主义"},"children":[{"data":{"id":"djsb5r412tc0","created":1783424322143,"text":"主观自生，生而知之；关键词：“我”、“心”、“我思故我在”"},"children":[]}]},{"data":{"text":"客观唯心主义"},"children":[{"data":{"id":"djsb5s9oiu80","created":1783424324662,"text":"上帝或客观精神，来源于第三方；关键词：神、上帝、绝对精神、绝对理念"},"children":[]}]}]},{"data":{"text":"② 唯物主义（反映论）"},"children":[{"data":{"text":"旧唯物主义"},"children":[{"data":{"id":"djsb5ysnd5s0","created":1783424338870,"text":"以感性直观，消极被动，照镜子，机械反映论"},"children":[]}]},{"data":{"text":"辩证唯物主义"},"children":[{"data":{"id":"djsb616lr3s0","created":1783424344067,"text":"以实践为基础，能动反映论"},"children":[]}]}]}]},{"data":{"text":"2. 认识的本质"},"children":[{"data":{"text":"主体在实践基础上对客体的能动反映"},"children":[{"data":{"text":"① 主客体的相互作用"},"children":[{"data":{"id":"djsb68i0pcw0","created":1783424359995,"text":"主体客体化，客体主体化，双向运动，换位思考"},"children":[]}]},{"data":{"text":"② 强调主体的能动性"},"children":[{"data":{"id":"djsb6dqe3fk0","created":1783424371385,"text":"自身"},"children":[]}]}]}]}]},{"data":{"text":"三、 认识的发展过程"},"children":[{"data":{"text":"具体过程","expandState":"expand"},"children":[{"data":{"text":"实践 -> 认识（物质 -> 精神）","expandState":"expand"},"children":[{"data":{"text":"实践->感性认识，上升到理性认识(第一次飞跃)"},"children":[]},{"data":{"text":"感性与理性"},"children":[{"data":{"text":"概念"},"children":[{"data":{"text":"感性：实践基础上，感觉器官，外部、现象、各个方面"},"children":[]},{"data":{"text":"理性：在大量感性材料基础上，抽象思维，本质、内部、整体"},"children":[]}]},{"data":{"text":"特征"},"children":[{"data":{"text":"感性：初级阶段，直观性、具体性、不深刻的局限性"},"children":[]},{"data":{"text":"理性：高级阶段，抽象性、间接性，深刻，容易造成脱离现实"},"children":[]}]},{"data":{"text":"形式"},"children":[{"data":{"text":"感性"},"children":[{"data":{"text":"感觉"},"children":[]},{"data":{"text":"知觉"},"children":[]},{"data":{"text":"表象（感性认识的最高阶段）"},"children":[]}]}]},{"data":{"text":"理性"},"children":[{"data":{"text":"概念"},"children":[]},{"data":{"text":"判断"},"children":[]},{"data":{"text":"推理（理性认识的最高阶段）"},"children":[]}]},{"data":{"text":"关系"},"children":[{"data":{"text":"① 理性认识依赖于感性"},"children":[]},{"data":{"text":"② 感性有待于上升理性"},"children":[]},{"data":{"text":"③ 相互渗透"},"children":[]}]},{"data":{"text":"方法论"},"children":[{"data":{"text":"不能割裂，二者辩证统一，如果割裂就会走向","expandState":"expand"},"children":[{"data":{"text":"唯理论（夸大理性，教条主义错误）"},"children":[]},{"data":{"text":"经验论（夸大感性，经验主义错误）"},"children":[]}]}]}]},{"data":{"text":"第一次飞跃的条件"},"children":[{"data":{"text":"① 投身实践，深入调研，获得大量丰富的感性材料"},"children":[]},{"data":{"text":"② 运用抽象思维（去粗取精，去伪存真，由此及彼，由表及里），上升到理性认识"},"children":[]}]}]},{"data":{"text":"认识 -> 实践"},"children":[{"data":{"text":"第二次飞跃：理性认识 -> 实践"},"children":[]},{"data":{"text":"更为重要"},"children":[{"data":{"id":"djsb98ud81s0","created":1783424595834,"text":"认识的目的"},"children":[]},{"data":{"id":"djsb9cx5rpk0","created":1783424604710,"text":"检验标准"},"children":[]}]},{"data":{"text":"中介环节"},"children":[{"data":{"id":"djsb9ggxpq80","created":1783424612436,"text":"最后环节，理论为群众掌握"},"children":[]}]}]},{"data":{"id":"djtv3is56qo0","created":1783582129437,"text":"认识发展过程中的理性和非理性因素的作用"},"children":[{"data":{"id":"djtv555ig5s0","created":1783582256499,"text":"非理性因素"},"children":[{"data":{"id":"djtv5c7jexs0","created":1783582271859,"text":"情感、意志"},"children":[]},{"data":{"id":"djtv5gr3bjs0","created":1783582281748,"text":"不自觉、非逻辑"},"children":[]},{"data":{"id":"djtv5kthjqw0","created":1783582290600,"text":"联想、想象、猜测、直觉、顿悟、灵感","font-weight":"bold"},"children":[]}]},{"data":{"id":"djtv5w4a3wg0","created":1783582315197,"text":"作用"},"children":[{"data":{"id":"djtv5yeld340","created":1783582320175,"text":"理性因素"},"children":[{"data":{"id":"djtv61e9syo0","created":1783582326685,"text":"决定作用"},"children":[]}]},{"data":{"id":"djtv63nnuyw0","created":1783582331607,"text":"非理性因素","font-weight":"bold"},"children":[{"data":{"id":"djtv68qvguw0","created":1783582342685,"text":"激活、驱动"},"children":[]},{"data":{"id":"djtv6cdq2n40","created":1783582350597,"text":"重要作用"},"children":[{"data":{"id":"djtv6xo19p40","created":1783582396933,"text":"积极"},"children":[]},{"data":{"id":"djtv70386so0","created":1783582402205,"text":"消极","font-weight":"bold"},"children":[{"data":{"id":"djtv7lzoyns0","created":1783582449881,"text":"导致偏差、错误就是难免的"},"children":[]}]}]}]}]},{"data":{"id":"djtv85vk7540","created":1783582493166,"text":"分支主题"},"children":[]}]}]},{"data":{"text":"2. 总过程 / 总规律"},"children":[]}]},{"data":{"text":"四、 认识的目的和任务"},"children":[{"data":{"text":"① 获得真理"},"children":[]},{"data":{"text":"② 价值"},"children":[]}]}]},"template":"default","theme":"fresh-blue","version":"1.4.43"}