{"root":{"data":{"text":"辩证法"},"children":[{"data":{"text":"两大观点","layout_mind_offset":{"x":-162,"y":795}},"children":[{"data":{"text":"联系"},"children":[]},{"data":{"text":"发展"},"children":[]}]},{"data":{"text":"三大规律"},"children":[{"data":{"text":"对立统一规律"},"children":[]},{"data":{"text":"质量互变规律"},"children":[]},{"data":{"text":"否定之否定规律"},"children":[]}]},{"data":{"text":"五大环节（范畴）"},"children":[{"data":{"text":"内容与形式"},"children":[]},{"data":{"text":"现象与本质"},"children":[]},{"data":{"text":"原因与结果"},"children":[]},{"data":{"text":"必然与偶然"},"children":[]},{"data":{"text":"可能与现实"},"children":[]}]},{"data":{"text":"六大思维能力"},"children":[{"data":{"text":"辩证思维"},"children":[]},{"data":{"text":"历史思维"},"children":[]},{"data":{"text":"系统思维"},"children":[]},{"data":{"text":"战略思维"},"children":[]},{"data":{"text":"底线思维"},"children":[]},{"data":{"text":"创新思维"},"children":[]}]},{"data":{"text":"一、联系观"},"children":[]},{"data":{"text":"概念"},"children":[]},{"data":{"text":"特征"},"children":[{"data":{"text":"客观性"},"children":[{"data":{"text":"联系客观存在，事物本身固有，不以人的意志为转移。"},"children":[]},{"data":{"text":"方法论：认识事物要从事物所固有的联系出发。"},"children":[]}]},{"data":{"text":"普遍性"},"children":[{"data":{"text":"整个世界是一个普遍联系的有机整体。"},"children":[]},{"data":{"text":"时时有联系，事事有联系，无处不在，无时不有。"},"children":[]},{"data":{"text":"方法论"},"children":[{"data":{"text":"承认联系普遍存在"},"children":[]},{"data":{"text":"具体联系具体分析"},"children":[]}]}]},{"data":{"text":"多样性"},"children":[{"data":{"text":"内部和外部（相对）"},"children":[]},{"data":{"text":"直接和间接（中介）"},"children":[]},{"data":{"text":"必然与偶然（趋势）"},"children":[]},{"data":{"text":"本质与非本质（根本性质）"},"children":[]}]},{"data":{"text":"条件性"},"children":[{"data":{"text":"联系是有条件的，条件对事物有促进/制约作用。"},"children":[]},{"data":{"text":"条件可以改变，但不是任意改变，必须符合客观规律。"},"children":[]},{"data":{"text":"方法论"},"children":[{"data":{"text":"坚持唯物辩证法条件论，反对唯心主义无条件论和唯条件论"},"children":[]},{"data":{"text":"化不利条件为有利条件。"},"children":[]}]}]}]},{"data":{"text":"关系：系统思维"},"children":[]},{"data":{"text":"方法论"},"children":[{"data":{"text":"承认联系普遍存在。"},"children":[]},{"data":{"text":"先分析事物具体联系，然后确立整体性、开放性原则，从动态中把握事物的普遍联系。"},"children":[]}]},{"data":{"text":"二、发展观"},"children":[]},{"data":{"text":"概念"},"children":[]},{"data":{"text":"实质：新事物产生，旧事物灭亡。"},"children":[{"data":{"text":"概念"},"children":[{"data":{"text":"新事物：合乎历史发展方向，具有远大前途。"},"children":[]},{"data":{"text":"旧事物：丧失历史必然性，日趋灭亡。"},"children":[]}]},{"data":{"text":"判断标准"},"children":[{"data":{"text":"不取决于时间先后和形式新旧"},"children":[]},{"data":{"text":"概念"},"children":[]}]},{"data":{"text":"新事物战胜旧事物的原因"},"children":[{"data":{"text":"与环境的关系"},"children":[]},{"data":{"text":"与旧事物的关系"},"children":[]},{"data":{"text":"在社会历史领域"},"children":[]}]}]},{"data":{"text":"关系：过程论。"},"children":[{"data":{"text":"整个世界是过程的集合体。"},"children":[]},{"data":{"text":"任何事物都是过程。"},"children":[]},{"data":{"text":"任何事物都有其产生、发展、消亡的过程。"},"children":[]},{"data":{"text":"任何事物都有其过去、现在、未来。"},"children":[]}]},{"data":{"text":"方法论"},"children":[{"data":{"text":"要用发展的眼光看问题。"},"children":[]},{"data":{"text":"了解过去，观察现在，展望未来。"},"children":[]}]},{"data":{"text":"三、对立统一规律"},"children":[]},{"data":{"text":"核心内容"},"children":[{"data":{"text":"矛盾的同一性和斗争性"},"children":[]},{"data":{"text":"矛盾的普遍性和特殊性"},"children":[]},{"data":{"text":"矛盾的不平衡性"},"children":[]}]},{"data":{"text":"1. 矛盾的同一性和斗争性"},"children":[{"data":{"text":"概念"},"children":[{"data":{"text":"同一性"},"children":[{"data":{"text":"相互依存，相互依赖，互为前提，缺一不可，并处于同一个统一体中"},"children":[]},{"data":{"text":"相互贯通，在一定条件下相互转化。"},"children":[]}]},{"data":{"text":"斗争性：相互排斥，分为对抗性、非对抗性。"},"children":[]}]},{"data":{"text":"关系"},"children":[{"data":{"text":"相辅相成，相互联结，不可分割，缺一不可。"},"children":[]},{"data":{"text":"斗争性寓于同一性中，同一性通过斗争性来体现。"},"children":[]},{"data":{"text":"无条件的绝对的斗争性，有条件的相对的同一性，两者相结合构成矛盾运动，推动发展（动力）。"},"children":[]}]},{"data":{"text":"作用"},"children":[{"data":{"text":"同一性的作用"},"children":[{"data":{"text":"是事物存在和发展的前提。"},"children":[]},{"data":{"text":"使矛盾双方相互吸收有利于自身因素，各自发展。"},"children":[]},{"data":{"text":"规定着事物转化的可能和趋势，有规律地向对立面转化。"},"children":[]}]},{"data":{"text":"斗争性的作用"},"children":[{"data":{"text":"促使矛盾双方力量对比发生变化，没有改变统一体的性质（量变阶段）。"},"children":[]},{"data":{"text":"使矛盾统一体向另一种矛盾统一体过渡的决定力量（质变阶段）。"},"children":[]},{"data":{"text":"规定着量变到质变。"},"children":[]},{"data":{"text":"二者共同发挥作用。"},"children":[]}]}]},{"data":{"text":"方法论"},"children":[{"data":{"text":"在对立中把握同一，在同一中把握对立。"},"children":[]},{"data":{"text":"一分为二看问题。"},"children":[]}]}]},{"data":{"text":"2. 矛盾的普遍性和特殊性"},"children":[{"data":{"text":"概念"},"children":[{"data":{"text":"普遍性：时时有矛盾，事事有矛盾，无处不在，无时不有。"},"children":[]},{"data":{"text":"特殊性"},"children":[{"data":{"text":"不同事物，其矛盾特点不同。"},"children":[]},{"data":{"text":"同一事物在不同发展阶段其矛盾特点不同。"},"children":[]},{"data":{"text":"构成事物的诸多矛盾以及每一个矛盾的不同方面其地位、性质、作用不同。"},"children":[]}]}]},{"data":{"text":"关系"},"children":[{"data":{"text":"辩证统一，不可分割。"},"children":[]},{"data":{"text":"任何事物都是共性与个性的统一。"},"children":[]},{"data":{"text":"共性寓于个性之中。"},"children":[]},{"data":{"text":"矛盾问题精髓：共性与个性，绝对与相对。"},"children":[]},{"data":{"text":"人的认识一般规律：个别 -> 一般 -> 个别。"},"children":[]}]},{"data":{"text":"方法论"},"children":[{"data":{"text":"承认矛盾普遍存在。"},"children":[]},{"data":{"text":"具体问题具体分析。"},"children":[]}]}]}]},"template":"default","theme":"fresh-blue","version":"1.4.43"}