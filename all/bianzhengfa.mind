{"root":{"data":{"text":"辩证法总纲 "},"children":[{"data":{"text":"两大观点","layout":null},"children":[{"data":{"text":"联系","expandState":"expand","layout":null},"children":[{"data":{"id":"djqi4uipg9c0","created":1783240879053,"text":"概念","layout":null},"children":[{"data":{"id":"djqi3ul9w7k0","created":1783240800844,"text":"事物之间、事物内部诸要素之间相互影响、相互制约、相互作用的关系。","layout":null},"children":[]}]},{"data":{"id":"djqi4uip9m80","created":1783240879053,"text":"特征","layout":null},"children":[{"data":{"id":"djqi2wzpiq00","created":1783240727706,"text":"客观性","layout":null},"children":[{"data":{"id":"djqi2wzp4u00","created":1783240727706,"text":"联系客观存在，事物本身固有，不以人的意志为转移。","layout":null},"children":[]},{"data":{"id":"djqi2wzpc4g0","created":1783240727706,"text":"方法论：认识事物要从事物所固有的联系出发。","layout":null},"children":[]}]},{"data":{"id":"djqi2x0182o0","created":1783240727726,"text":"普遍性","font-weight":"bold","layout":null},"children":[{"data":{"id":"djqi2x01eeo0","created":1783240727726,"text":"整个世界是一个普遍联系的有机整体。","layout":null},"children":[]},{"data":{"id":"djqi2x01a680","created":1783240727726,"text":"时时有联系，事事有联系，无处不在，无时不有。","layout":null},"children":[]},{"data":{"id":"djqi2x01zu80","created":1783240727727,"text":"方法论","layout":null},"children":[{"data":{"id":"djqi2x01ihk0","created":1783240727727,"text":"承认联系普遍存在","layout":null},"children":[]},{"data":{"id":"djqi2x01z8g0","created":1783240727727,"text":"具体联系具体分析","layout":null},"children":[]}]}]},{"data":{"id":"djqi2x0e3pc0","created":1783240727748,"text":"多样性","layout":null},"children":[{"data":{"id":"djqi2x0eaow0","created":1783240727748,"text":"内部和外部（相对）","layout":null},"children":[]},{"data":{"id":"djqi2x0e31k0","created":1783240727748,"text":"直接和间接（中介）","layout":null},"children":[]},{"data":{"id":"djqi2x0e2540","created":1783240727748,"text":"必然与偶然（趋势）","layout":null},"children":[]},{"data":{"id":"djqi2x0e8ps0","created":1783240727748,"text":"本质与非本质（根本性质）","layout":null},"children":[]}]},{"data":{"id":"djqi2x0rwi00","created":1783240727771,"text":"条件性","layout":null},"children":[{"data":{"id":"djqi2x0ry8g0","created":1783240727771,"text":"联系是有条件的，条件对事物有促进/制约作用。","layout":null},"children":[]},{"data":{"id":"djqi2x0s0k80","created":1783240727771,"text":"条件可以改变，但不是任意改变，必须符合客观规律。","layout":null},"children":[]},{"data":{"id":"djqi2x0ruc00","created":1783240727771,"text":"方法论","layout":null},"children":[{"data":{"id":"djqi2x0rxtk0","created":1783240727771,"text":"坚持唯物辩证法条件论，反对唯心主义无条件论和唯条件论","layout":null},"children":[]},{"data":{"id":"djqi2x0roi80","created":1783240727771,"text":"化不利条件为有利条件。","layout":null},"children":[]}]}]}]},{"data":{"id":"djqi4uiqmo80","created":1783240879055,"text":"关系：系统思维","layout":null},"children":[]},{"data":{"id":"djqi4uiqo1k0","created":1783240879055,"text":"方法论","layout":null},"children":[{"data":{"id":"djqi2wxqeko0","created":1783240727587,"text":"承认联系普遍存在。","layout":null},"children":[]},{"data":{"id":"djqi2wy58hk0","created":1783240727612,"text":"先分析事物具体联系，然后确立整体性、开放性原则，从动态中把握事物的普遍联系。","layout":null},"children":[]}]}]},{"data":{"text":"发展","expandState":"expand","layout":null},"children":[{"data":{"text":"概念","layout":null},"children":[{"data":{"id":"djqi5mf4bm80","created":1783240939786,"text":"前进、上升的运动。","layout":null},"children":[]}]},{"data":{"text":"实质：新事物产生，旧事物灭亡。","layout":null},"children":[{"data":{"text":"概念","layout":null},"children":[{"data":{"id":"djqi2wuujco0","created":1783240727413,"text":"新事物：合乎历史发展方向，具有远大前途。","layout":null},"children":[]},{"data":{"id":"djqi2wv6ocg0","created":1783240727433,"text":"旧事物：丧失历史必然性，日趋灭亡。","layout":null},"children":[]}]},{"data":{"text":"判断标准","layout":null},"children":[{"data":{"id":"djqi2wtruw00","created":1783240727348,"text":"不取决于时间先后和形式新旧","layout":null},"children":[]},{"data":{"id":"djqi2wu7h2g0","created":1783240727374,"text":"概念","layout":null},"children":[]}]},{"data":{"text":"新事物战胜旧事物的原因","layout":null},"children":[{"data":{"id":"djqi2wskmyg0","created":1783240727275,"text":"与环境的关系","layout":null},"children":[{"data":{"id":"djqi6glvgow0","created":1783241005498,"text":"具有强大生命力、本质的原因","layout":null},"children":[]}]},{"data":{"id":"djqi2wsvjbk0","created":1783240727293,"text":"与旧事物的关系","layout":null},"children":[{"data":{"id":"djqi6zrduxs0","created":1783241047190,"text":"具有强大生命力、本质的原因"},"children":[]}]},{"data":{"id":"djqi2wt66nk0","created":1783240727311,"text":"在社会历史领域","layout":null},"children":[]}]}]},{"data":{"text":"关系","layout":null},"children":[{"data":{"id":"djqi79d3deg0","created":1783241068094,"text":"过程论","expandState":"expand"},"children":[{"data":{"text":"整个世界是过程的集合体。","layout":null},"children":[]},{"data":{"text":"任何事物都是过程。","layout":null},"children":[]},{"data":{"id":"djqi2wrfig00","created":1783240727206,"text":"任何事物都有其产生、发展、消亡的过程。","layout":null},"children":[]},{"data":{"id":"djqi2wrpz6o0","created":1783240727223,"text":"任何事物都有其过去、现在、未来。","layout":null},"children":[]}]}]},{"data":{"text":"方法论","layout":null},"children":[{"data":{"id":"djqi2wpyz6o0","created":1783240727118,"text":"要用发展的眼光（历史的眼光）看问题。","layout":null},"children":[]},{"data":{"id":"djqi2wq9uxs0","created":1783240727136,"text":"了解过去，观察现在，展望未来。","layout":null},"children":[]}]}]}]},{"data":{"text":"三大规律","layout":null},"children":[{"data":{"text":"对立统一规律","layout":null},"children":[]},{"data":{"text":"质量互变规律","layout":null},"children":[]},{"data":{"text":"否定之否定规律","layout":null},"children":[]}]},{"data":{"text":"五大环节（范畴）","layout":null},"children":[{"data":{"text":"内容与形式","layout":null},"children":[]},{"data":{"text":"现象与本质","layout":null},"children":[]},{"data":{"text":"原因与结果","layout":null},"children":[]},{"data":{"text":"必然与偶然","layout":null},"children":[]},{"data":{"text":"可能与现实","layout":null},"children":[]}]},{"data":{"text":"六大思维能力","layout":null},"children":[{"data":{"id":"djqi2x3c8xs0","created":1783240727926,"text":"辩证思维","layout":null},"children":[]},{"data":{"id":"djqi2x3orgg0","created":1783240727947,"text":"历史思维","layout":null},"children":[]},{"data":{"id":"djqi2x3zb200","created":1783240727965,"text":"系统思维","layout":null},"children":[]},{"data":{"id":"djqi2x4a5jc0","created":1783240727983,"text":"战略思维","layout":null},"children":[]},{"data":{"id":"djqi2x4ll4o0","created":1783240728002,"text":"底线思维","layout":null},"children":[]},{"data":{"id":"djqi2x4w7vk0","created":1783240728020,"text":"创新思维","layout":null},"children":[]}]},{"data":{"text":"三、对立统一规律","layout":null},"children":[]},{"data":{"text":"核心内容","layout":null},"children":[{"data":{"text":"矛盾的同一性和斗争性","layout":null},"children":[]},{"data":{"text":"矛盾的普遍性和特殊性","layout":null},"children":[]},{"data":{"text":"矛盾的不平衡性","layout":null},"children":[]}]},{"data":{"text":"1. 矛盾的同一性和斗争性","layout":null},"children":[{"data":{"text":"概念","layout":null},"children":[{"data":{"text":"同一性","layout":null},"children":[{"data":{"id":"djqi2wiq1z40","created":1783240726679,"text":"相互依存，相互依赖，互为前提，缺一不可，并处于同一个统一体中","layout":null},"children":[]},{"data":{"id":"djqi2wjeo4g0","created":1783240726721,"text":"相互贯通，在一定条件下相互转化。","layout":null},"children":[]}]},{"data":{"text":"斗争性：相互排斥，分为对抗性、非对抗性。","layout":null},"children":[]}]},{"data":{"text":"关系","layout":null},"children":[{"data":{"text":"相辅相成，相互联结，不可分割，缺一不可。","layout":null},"children":[]},{"data":{"text":"斗争性寓于同一性中，同一性通过斗争性来体现。","layout":null},"children":[]},{"data":{"text":"无条件的绝对的斗争性，有条件的相对的同一性，两者相结合构成矛盾运动，推动发展（动力）。","layout":null},"children":[]}]},{"data":{"text":"作用","layout":null},"children":[{"data":{"text":"同一性的作用","layout":null},"children":[{"data":{"id":"djqi2wctl0g0","created":1783240726323,"text":"是事物存在和发展的前提。","layout":null},"children":[]},{"data":{"id":"djqi2wd741s0","created":1783240726345,"text":"使矛盾双方相互吸收有利于自身因素，各自发展。","layout":null},"children":[]},{"data":{"id":"djqi2wdkfzk0","created":1783240726368,"text":"规定着事物转化的可能和趋势，有规律地向对立面转化。","layout":null},"children":[]}]},{"data":{"text":"斗争性的作用","layout":null},"children":[{"data":{"id":"djqi2wapd5s0","created":1783240726195,"text":"促使矛盾双方力量对比发生变化，没有改变统一体的性质（量变阶段）。","layout":null},"children":[]},{"data":{"id":"djqi2wb53mw0","created":1783240726221,"text":"使矛盾统一体向另一种矛盾统一体过渡的决定力量（质变阶段）。","layout":null},"children":[]},{"data":{"id":"djqi2wbibc80","created":1783240726243,"text":"规定着量变到质变。","layout":null},"children":[]},{"data":{"id":"djqi2wbx5480","created":1783240726269,"text":"二者共同发挥作用。","layout":null},"children":[]}]}]},{"data":{"id":"djqi2wk89ew0","created":1783240726770,"text":"方法论","layout":null},"children":[{"data":{"id":"djqi2wk7txk0","created":1783240726770,"text":"在对立中把握同一，在同一中把握对立。","layout":null},"children":[]},{"data":{"id":"djqi2wk83pk0","created":1783240726770,"text":"一分为二看问题。","layout":null},"children":[]}]}]},{"data":{"text":"2. 矛盾的普遍性和特殊性","layout":null},"children":[{"data":{"text":"概念","layout":null},"children":[{"data":{"id":"djqi2w8t10o0","created":1783240726080,"text":"普遍性：时时有矛盾，事事有矛盾，无处不在，无时不有。","layout":null},"children":[]},{"data":{"id":"djqi2w96zs00","created":1783240726103,"text":"特殊性","layout":null},"children":[{"data":{"id":"djqi2w96ob40","created":1783240726103,"text":"不同事物，其矛盾特点不同。","layout":null},"children":[]},{"data":{"id":"djqi2w978uw0","created":1783240726104,"text":"同一事物在不同发展阶段其矛盾特点不同。","layout":null},"children":[]},{"data":{"id":"djqi2w97mfc0","created":1783240726104,"text":"构成事物的诸多矛盾以及每一个矛盾的不同方面其地位、性质、作用不同。","layout":null},"children":[]}]}]},{"data":{"text":"关系","layout":null},"children":[{"data":{"id":"djqi2w6oc3c0","created":1783240725951,"text":"辩证统一，不可分割。","layout":null},"children":[]},{"data":{"id":"djqi2w71etk0","created":1783240725973,"text":"任何事物都是共性与个性的统一。","layout":null},"children":[]},{"data":{"id":"djqi2w7dj9c0","created":1783240725993,"text":"共性寓于个性之中。","layout":null},"children":[]},{"data":{"id":"djqi2w7q6dk0","created":1783240726014,"text":"矛盾问题精髓：共性与个性，绝对与相对。","layout":null},"children":[]},{"data":{"id":"djqi2w83e5k0","created":1783240726037,"text":"人的认识一般规律：个别 -> 一般 -> 个别。","layout":null},"children":[]}]},{"data":{"id":"djqi2w9wht40","created":1783240726146,"text":"方法论","layout":null},"children":[{"data":{"id":"djqi2w9x0ag0","created":1783240726147,"text":"承认矛盾普遍存在。","layout":null},"children":[]},{"data":{"id":"djqi2w9x3a00","created":1783240726147,"text":"具体问题具体分析。","layout":null},"children":[]}]}]}]},"template":"default","theme":"fresh-blue","version":"1.4.43"}