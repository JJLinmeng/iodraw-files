{"root":{"data":{"text":"马克思主义哲学"},"children":[{"data":{"text":"唯物论","layout":null},"children":[{"data":{"text":"（一）五观","layout":null},"children":[{"data":{"text":"物质观","layout":null},"children":[{"data":{"text":"概念","layout":null},"children":[{"data":{"text":"客观实在","expandState":"expand","layout":null},"children":[{"data":{"text":"不依赖于人的感觉而存在","layout":null},"children":[]},{"data":{"text":"为人的感觉所反映（能动反映）","layout":null},"children":[]}]}]},{"data":{"text":"特征","layout":null},"children":[{"data":{"text":"客观实在性：物质的共同特性、唯一共性","layout":null},"children":[]}]},{"data":{"text":"关系","layout":null},"children":[{"data":{"text":"不同阶段唯物主义对物质概念的看法","expandState":"expand","layout":null},"children":[{"data":{"text":"古代朴素唯物主义：归结为一种或几种具体物质形态（金、木、水、火、气）","layout":null},"children":[]},{"data":{"text":"近代形而上学唯物主义：归结为最小单位 —— 原子","layout":null},"children":[]},{"data":{"text":"现代辩证唯物主义","layout":null},"children":[]}]},{"data":{"text":"哲学物质范畴与自然科学物质概念的关系：共性与个性","layout":null},"children":[]}]},{"data":{"text":"（4）方法论","layout":null},"children":[{"data":{"text":"坚持唯物主义一元论","layout":null},"children":[]},{"data":{"text":"坚持能动反映论和可知论","layout":null},"children":[]},{"data":{"text":"体现唯物论与辩证法的统一","layout":null},"children":[]},{"data":{"text":"体现唯物主义自然观与历史观的统一","layout":null},"children":[]}]}]},{"data":{"text":"运动观","layout":null},"children":[{"data":{"text":"概念","layout":null},"children":[{"data":{"text":"一切事物和现象","layout":null},"children":[]},{"data":{"text":"变化及过程","layout":null},"children":[]}]},{"data":{"text":"特性","layout":null},"children":[{"data":{"text":"客观实在性","layout":null},"children":[]}]},{"data":{"text":"关系","layout":null},"children":[{"data":{"text":"运动和物质的关系","expandState":"expand","layout":null},"children":[{"data":{"text":"二者不可分割（离开物质谈运动犯唯心主义错误）","layout":null},"children":[]},{"data":{"text":"运动是物质的根本属性","layout":null},"children":[]}]},{"data":{"text":"运动和静止的关系","expandState":"expand","layout":null},"children":[{"data":{"text":"静止","expandState":"expand","layout":null},"children":[{"data":{"text":"是物质运动的特殊状态","layout":null},"children":[]},{"data":{"text":"在一定条件下保持稳定","layout":null},"children":[]},{"data":{"text":"包含两种状态：空间位置不变、根本性质不变","layout":null},"children":[]}]},{"data":{"text":"关系","expandState":"expand","layout":null},"children":[{"data":{"text":"不可分割","layout":null},"children":[]},{"data":{"text":"相互渗透","layout":null},"children":[]},{"data":{"text":"无条件的绝对运动 + 有条件的相对静止，共同构成矛盾运动","layout":null},"children":[]}]}]}]},{"data":{"id":"djoxvtns2lc0","created":1783082189751,"text":"方法论","layout":null},"children":[{"data":{"id":"djoxvx3mk800","created":1783082197239,"text":"一切以具体时间、地点、条件的转移而转移","layout":null},"children":[]}]}]},{"data":{"text":"时空观","expandState":"expand","layout":null},"children":[{"data":{"text":"概念","layout":null},"children":[{"data":{"text":"时间：物质运动的持续性、顺序性","layout":null},"children":[]},{"data":{"text":"空间：物质运动的广延性、伸张性","layout":null},"children":[]}]},{"data":{"text":"特征","layout":null},"children":[{"data":{"text":"时间：一维性（一去不复返）、客观性","layout":null},"children":[]},{"data":{"text":"空间：三维性（长宽高）、客观性","layout":null},"children":[]}]},{"data":{"text":"关系","layout":null},"children":[{"data":{"text":"时空与物质运动的关系","expandState":"expand","layout":null},"children":[{"data":{"text":"二者不可分割","layout":null},"children":[]},{"data":{"text":"时空是物质运动的基本存在方式","layout":null},"children":[]}]},{"data":{"text":"时空的特性","expandState":"expand","layout":null},"children":[{"data":{"text":"具体物质形态的时空是有限的","layout":null},"children":[]},{"data":{"text":"整个物质世界的时空是无限的","layout":null},"children":[]}]}]},{"data":{"text":"方法论","layout":null},"children":[{"data":{"text":"一切以具体时间、地点、条件的转移而转移","layout":null},"children":[]}]}]},{"data":{"text":"实践观","layout":null},"children":[{"data":{"text":"核心逻辑：实践活动导致世界二重化","layout":null},"children":[{"data":{"text":"世界划分","expandState":"expand","layout":null},"children":[{"data":{"text":"客观世界（物质世界）：自然界、人类社会","layout":null},"children":[]},{"data":{"text":"主观世界（精神世界）：思维领域","layout":null},"children":[]}]},{"data":{"text":"自然界分化出人类社会","layout":null},"children":[]},{"data":{"text":"客观世界分化出主观世界","layout":null},"children":[]}]},{"data":{"text":"核心结论","layout":null},"children":[{"data":{"text":"人的实践活动是自然与社会、客观与主观分化又统一的关键","layout":null},"children":[]}]}]},{"data":{"text":"意识观","layout":null},"children":[{"data":{"text":"物质决定意识","layout":null},"children":[{"data":{"text":"意识的起源","expandState":"expand","layout":null},"children":[{"data":{"text":"是自然界长期发展的产物（三阶段）","expandState":"expand","layout":null},"children":[{"data":{"text":"低等生物：刺激感应性","layout":null},"children":[]},{"data":{"text":"高等动物：感觉和心理","layout":null},"children":[]},{"data":{"text":"人类：意识","layout":null},"children":[]}]},{"data":{"text":"是社会历史发展的产物","expandState":"expand","layout":null},"children":[{"data":{"text":"实践 / 劳动：对意识产生起决定性作用","layout":null},"children":[]},{"data":{"text":"语言：对意识发展起促进作用","layout":null},"children":[]}]}]},{"data":{"text":"意识的本质","expandState":"expand","layout":null},"children":[{"data":{"text":"意识≠人脑，意识是人脑这一特殊物质的机能和属性","layout":null},"children":[]},{"data":{"text":"意识是客观世界的主观映象（主观反映客观）","layout":null},"children":[]},{"data":{"text":"是客观内容与主观形式的统一：内容客观、形式主观","layout":null},"children":[]},{"data":{"text":"意识≠物质，是物质的产物、意识是对也只能是对物质的反映、二者不能相互替代，但可以相互转化","layout":null},"children":[]}]}]},{"data":{"text":"意识反作用于物质（意识的能动作用）","layout":null},"children":[{"data":{"text":"任何意识都具有目的性和计划性","layout":null},"children":[]},{"data":{"text":"意识活动具有创造性","layout":null},"children":[]},{"data":{"text":"意识能够指导实践","layout":null},"children":[]},{"data":{"text":"意识能够调控人的行为和心理活动","layout":null},"children":[]},{"data":{"text":"特殊表现：人工智能","layout":null},"children":[]}]}]}]},{"data":{"text":"三原理","layout":null},"children":[{"data":{"text":"物质与意识的关系","layout":null},"children":[{"data":{"text":"物质决定意识","layout":null},"children":[]},{"data":{"text":"意识反作用于物质","layout":null},"children":[]}]},{"data":{"text":"主观能动性与客观规律的辩证关系","layout":null},"children":[{"data":{"text":"规律","layout":null},"children":[{"data":{"text":"概念","expandState":"expand","layout":null},"children":[{"data":{"text":"固有的","layout":null},"children":[]},{"data":{"text":"本质的、内在的、必然的、稳定的","layout":null},"children":[]}]},{"data":{"text":"分类","expandState":"expand","layout":null},"children":[{"data":{"text":"自然规律：自然界：自发、盲目的、无意识的","layout":null},"children":[]},{"data":{"text":"社会规律：人类社会：自觉、有目的的有意识的人发挥作用","layout":null},"children":[]}]},{"data":{"text":"对待规律的态度","expandState":"expand","layout":null},"children":[{"data":{"text":"可以发现、认识、利用规律","layout":null},"children":[]},{"data":{"text":"不能消灭、创造规律","layout":null},"children":[]}]}]},{"data":{"text":"二者关系","layout":null},"children":[{"data":{"text":"发挥主观能动性必须以尊重客观规律为前提","layout":null},"children":[]},{"data":{"text":"只有充分发挥主观能动性，才能认识和利用规律","layout":null},"children":[]}]}]},{"data":{"text":"世界的物质统一性原理","layout":null},"children":[{"data":{"text":"世界统一于物质，是多样性的统一","layout":null},"children":[]}]}]}]},{"data":{"text":"辩证法","layout":null},"children":[{"data":{"text":"两大观点","layout":null},"children":[{"data":{"text":"联系","expandState":"expand","layout":null},"children":[{"data":{"id":"djqi4uipg9c0","created":1783240879053,"text":"概念","layout":null},"children":[{"data":{"id":"djqi3ul9w7k0","created":1783240800844,"text":"事物之间、事物内部诸要素之间相互影响、相互制约、相互作用的关系。","layout":null},"children":[]}]},{"data":{"id":"djqi4uip9m80","created":1783240879053,"text":"特征","layout":null},"children":[{"data":{"id":"djqi2wzpiq00","created":1783240727706,"text":"客观性","layout":null},"children":[{"data":{"id":"djqi2wzp4u00","created":1783240727706,"text":"联系客观存在，事物本身固有，不以人的意志为转移。","layout":null},"children":[]},{"data":{"id":"djqi2wzpc4g0","created":1783240727706,"text":"方法论：认识事物要从事物所固有的联系出发。","layout":null},"children":[]}]},{"data":{"id":"djqi2x0182o0","created":1783240727726,"text":"普遍性","font-weight":"bold","layout":null},"children":[{"data":{"id":"djqi2x01eeo0","created":1783240727726,"text":"整个世界是一个普遍联系的有机整体。","layout":null},"children":[]},{"data":{"id":"djqi2x01a680","created":1783240727726,"text":"时时有联系，事事有联系，无处不在，无时不有。","layout":null},"children":[]},{"data":{"id":"djqi2x01zu80","created":1783240727727,"text":"方法论","layout":null},"children":[{"data":{"id":"djqi2x01ihk0","created":1783240727727,"text":"承认联系普遍存在","layout":null},"children":[]},{"data":{"id":"djqi2x01z8g0","created":1783240727727,"text":"具体联系具体分析","layout":null},"children":[]}]}]},{"data":{"id":"djqi2x0e3pc0","created":1783240727748,"text":"多样性","layout":null},"children":[{"data":{"id":"djqi2x0eaow0","created":1783240727748,"text":"内部和外部（相对）","layout":null},"children":[]},{"data":{"id":"djqi2x0e31k0","created":1783240727748,"text":"直接和间接（中介）","layout":null},"children":[]},{"data":{"id":"djqi2x0e2540","created":1783240727748,"text":"必然与偶然（趋势）","layout":null},"children":[]},{"data":{"id":"djqi2x0e8ps0","created":1783240727748,"text":"本质与非本质（根本性质）","layout":null},"children":[]}]},{"data":{"id":"djqi2x0rwi00","created":1783240727771,"text":"条件性","layout":null},"children":[{"data":{"id":"djqi2x0ry8g0","created":1783240727771,"text":"联系是有条件的，条件对事物有促进/制约作用。","layout":null},"children":[]},{"data":{"id":"djqi2x0s0k80","created":1783240727771,"text":"条件可以改变，但不是任意改变，必须符合客观规律。","layout":null},"children":[]},{"data":{"id":"djqi2x0ruc00","created":1783240727771,"text":"方法论","layout":null},"children":[{"data":{"id":"djqi2x0rxtk0","created":1783240727771,"text":"坚持唯物辩证法条件论，反对唯心主义无条件论和唯条件论","layout":null},"children":[]},{"data":{"id":"djqi2x0roi80","created":1783240727771,"text":"化不利条件为有利条件。","layout":null},"children":[]}]}]}]},{"data":{"id":"djqi4uiqmo80","created":1783240879055,"text":"关系：系统思维","layout":null},"children":[]},{"data":{"id":"djqi4uiqo1k0","created":1783240879055,"text":"方法论","layout":null},"children":[{"data":{"id":"djqi2wxqeko0","created":1783240727587,"text":"承认联系普遍存在。","layout":null},"children":[]},{"data":{"id":"djqi2wy58hk0","created":1783240727612,"text":"先分析事物具体联系，然后确立整体性、开放性原则，从动态中把握事物的普遍联系。","layout":null},"children":[]}]}]},{"data":{"text":"发展","expandState":"expand","layout":null},"children":[{"data":{"text":"概念","layout":null},"children":[{"data":{"id":"djqi5mf4bm80","created":1783240939786,"text":"前进、上升的运动。","layout":null},"children":[]}]},{"data":{"text":"实质：新事物产生，旧事物灭亡。","layout":null},"children":[{"data":{"text":"概念","layout":null},"children":[{"data":{"id":"djqi2wuujco0","created":1783240727413,"text":"新事物：合乎历史发展方向，具有远大前途。","layout":null},"children":[]},{"data":{"id":"djqi2wv6ocg0","created":1783240727433,"text":"旧事物：丧失历史必然性，日趋灭亡。","layout":null},"children":[]}]},{"data":{"text":"判断标准","layout":null},"children":[{"data":{"id":"djqi2wtruw00","created":1783240727348,"text":"不取决于时间先后和形式新旧","layout":null},"children":[]},{"data":{"id":"djqi2wu7h2g0","created":1783240727374,"text":"概念","layout":null},"children":[]}]},{"data":{"text":"新事物战胜旧事物的原因","layout":null},"children":[{"data":{"id":"djqi2wskmyg0","created":1783240727275,"text":"与环境的关系","layout":null},"children":[{"data":{"id":"djqi6glvgow0","created":1783241005498,"text":"具有强大生命力、本质的原因","layout":null},"children":[]}]},{"data":{"id":"djqi2wsvjbk0","created":1783240727293,"text":"与旧事物的关系","layout":null},"children":[{"data":{"id":"djqi6zrduxs0","created":1783241047190,"text":"具有强大生命力、本质的原因","layout":null},"children":[]}]},{"data":{"id":"djqi2wt66nk0","created":1783240727311,"text":"在社会历史领域","layout":null},"children":[]}]}]},{"data":{"text":"关系","layout":null},"children":[{"data":{"id":"djqi79d3deg0","created":1783241068094,"text":"过程论","expandState":"expand","layout":null},"children":[{"data":{"text":"整个世界是过程的集合体。","layout":null},"children":[]},{"data":{"text":"任何事物都是过程。","layout":null},"children":[]},{"data":{"id":"djqi2wrfig00","created":1783240727206,"text":"任何事物都有其产生、发展、消亡的过程。","layout":null},"children":[]},{"data":{"id":"djqi2wrpz6o0","created":1783240727223,"text":"任何事物都有其过去、现在、未来。","layout":null},"children":[]}]}]},{"data":{"text":"方法论","layout":null},"children":[{"data":{"id":"djqi2wpyz6o0","created":1783240727118,"text":"要用发展的眼光（历史的眼光）看问题。","layout":null},"children":[]},{"data":{"id":"djqi2wq9uxs0","created":1783240727136,"text":"了解过去，观察现在，展望未来。","layout":null},"children":[]}]}]}]},{"data":{"text":"三大规律","layout":null},"children":[{"data":{"text":"对立统一规律","layout":null,"expandState":"expand"},"children":[{"data":{"text":"1. 矛盾的同一性和斗争性","layout":null},"children":[{"data":{"text":"概念","layout":null},"children":[{"data":{"text":"同一性","layout":null},"children":[{"data":{"id":"djqi2wiq1z40","created":1783240726679,"text":"相互依存，相互依赖，互为前提，缺一不可，并处于同一个统一体中","layout":null},"children":[]},{"data":{"id":"djqi2wjeo4g0","created":1783240726721,"text":"相互贯通，在一定条件下相互转化。","layout":null},"children":[]}]},{"data":{"text":"斗争性：相互排斥，分为对抗性、非对抗性。","layout":null},"children":[]}]},{"data":{"text":"关系","layout":null},"children":[{"data":{"text":"相辅相成，相互联结，不可分割，缺一不可。","layout":null},"children":[]},{"data":{"text":"斗争性寓于同一性中，同一性通过斗争性来体现。","layout":null},"children":[]},{"data":{"text":"无条件的绝对的斗争性，有条件的相对的同一性，两者相结合构成矛盾运动，推动发展（动力）。","layout":null},"children":[]}]},{"data":{"text":"作用","layout":null},"children":[{"data":{"text":"同一性的作用","layout":null},"children":[{"data":{"id":"djqi2wctl0g0","created":1783240726323,"text":"是事物存在和发展的前提。","layout":null},"children":[]},{"data":{"id":"djqi2wd741s0","created":1783240726345,"text":"使矛盾双方相互吸收有利于自身因素，各自发展。","layout":null},"children":[]},{"data":{"id":"djqi2wdkfzk0","created":1783240726368,"text":"规定着事物转化的可能和趋势，有规律地向对立面转化。","layout":null},"children":[]}]},{"data":{"text":"斗争性的作用","layout":null},"children":[{"data":{"id":"djqi2wapd5s0","created":1783240726195,"text":"促使矛盾双方力量对比发生变化，没有改变统一体的性质（量变阶段）。","layout":null},"children":[]},{"data":{"id":"djqi2wb53mw0","created":1783240726221,"text":"使矛盾统一体向另一种矛盾统一体过渡的决定力量（质变阶段）。","layout":null},"children":[]},{"data":{"id":"djqi2wbibc80","created":1783240726243,"text":"规定着量变到质变。","layout":null},"children":[]},{"data":{"id":"djqi2wbx5480","created":1783240726269,"text":"二者共同发挥作用。","layout":null},"children":[]}]}]},{"data":{"id":"djqi2wk89ew0","created":1783240726770,"text":"方法论","layout":null},"children":[{"data":{"id":"djqi2wk7txk0","created":1783240726770,"text":"在对立中把握同一，在同一中把握对立。","layout":null},"children":[]},{"data":{"id":"djqi2wk83pk0","created":1783240726770,"text":"一分为二看问题。","layout":null},"children":[]}]}]},{"data":{"text":"2. 矛盾的普遍性和特殊性","layout":null},"children":[{"data":{"text":"概念","layout":null},"children":[{"data":{"id":"djqi2w8t10o0","created":1783240726080,"text":"普遍性","layout":null},"children":[{"data":{"id":"djqi9kym9b40","created":1783241250068,"text":"时时有矛盾，事事有矛盾，无处不在，无时不有。","layout":null},"children":[]}]},{"data":{"id":"djqi2w96zs00","created":1783240726103,"text":"特殊性","layout":null},"children":[{"data":{"id":"djqi2w96ob40","created":1783240726103,"text":"不同事物，其矛盾特点不同。","layout":null},"children":[]},{"data":{"id":"djqi2w978uw0","created":1783240726104,"text":"同一事物在不同发展阶段其矛盾特点不同。","layout":null},"children":[]},{"data":{"id":"djqi2w97mfc0","created":1783240726104,"text":"构成事物的诸多矛盾以及每一个矛盾的不同方面其地位、性质、作用不同。","layout":null},"children":[]}]}]},{"data":{"text":"关系","layout":null},"children":[{"data":{"id":"djqi2w6oc3c0","created":1783240725951,"text":"辩证统一，不可分割。","layout":null},"children":[]},{"data":{"id":"djqi2w71etk0","created":1783240725973,"text":"任何事物都是共性与个性的统一。","layout":null},"children":[]},{"data":{"id":"djqi2w7dj9c0","created":1783240725993,"text":"共性寓于个性之中。","layout":null},"children":[]},{"data":{"id":"djqi2w7q6dk0","created":1783240726014,"text":"矛盾问题精髓：共性与个性，绝对与相对。","layout":null},"children":[]},{"data":{"id":"djqi2w83e5k0","created":1783240726037,"text":"人的认识一般规律：个别 -> 一般 -> 个别。","layout":null},"children":[]}]},{"data":{"id":"djqi2w9wht40","created":1783240726146,"text":"方法论","layout":null},"children":[{"data":{"id":"djqi2w9x0ag0","created":1783240726147,"text":"承认矛盾普遍存在。","layout":null},"children":[]},{"data":{"id":"djqi2w9x3a00","created":1783240726147,"text":"具体问题具体分析。","layout":null},"children":[]}]}]},{"data":{"id":"djqi8gf4xvk0","created":1783241161819,"text":"3. 矛盾的不平衡性","layout":null,"expandState":"expand"},"children":[{"data":{"text":"1. 概念"},"children":[{"data":{"text":"构成事物的诸多矛盾以及矛盾的不同方面，其地位、性质、作用不同"},"children":[]}]},{"data":{"text":"2. 具体概念"},"children":[{"data":{"text":"① 主、次要矛盾"},"children":[]},{"data":{"text":"② 矛盾的主、次要方面"},"children":[]},{"data":{"text":"③ 事物的性质由主要矛盾的主要方面决定"},"children":[]}]},{"data":{"text":"3. 方法论"},"children":[{"data":{"text":"① 坚持“两点论”和“重点论”的统一"},"children":[]},{"data":{"text":"② 既要全面地看，又要看主流、大势"},"children":[]}]}]}]},{"data":{"text":"质量互变规律","layout":null,"expandState":"expand"},"children":[{"data":{"text":"1. 概念"},"children":[{"data":{"text":"① 质：内在规定性，认识事物的起点"},"children":[]},{"data":{"text":"② 量：数量关系，认识事物的精确化"},"children":[]},{"data":{"text":"③ 度："},"children":[{"data":{"text":"① 质量的统一在度中体现"},"children":[]},{"data":{"text":"② 保持事物质的稳定性的数量界限（限度、幅度、范围）"},"children":[]},{"data":{"text":"③ 度的两端叫关节点"},"children":[]},{"data":{"text":"④ 超出度的范围，一物变他物"},"children":[]},{"data":{"text":"⑤ 方法论：适度原则（底线思维）"},"children":[]}]}]},{"data":{"text":"2. 规律"},"children":[{"data":{"text":"① 概念"},"children":[{"data":{"text":"① 量变：数量关系、排列次序的变化"},"children":[]},{"data":{"text":"② 质变：根本性变化"},"children":[]}]},{"data":{"text":"② 特征"},"children":[{"data":{"text":"① 量变：不显著变化、渐进性、连续性"},"children":[]},{"data":{"text":"② 质变：显著、飞跃性、中断性"},"children":[]}]}]},{"data":{"text":"3. 关系"},"children":[{"data":{"text":"① 量变是质变的必要准备"},"children":[]},{"data":{"text":"② 质变是量变的必然结果"},"children":[]},{"data":{"text":"③ 二者相互渗透"},"children":[]},{"data":{"text":"④ 交替循环，状态和过程"},"children":[]}]},{"data":{"text":"4. 方法论"},"children":[{"data":{"text":"1、渐进性和飞跃性的统一"},"children":[]},{"data":{"id":"djrazoqtwo00","created":1783322286850,"text":"2","expandState":"expand"},"children":[{"data":{"text":"① 在量变阶段，打好基础，为质变作准备"},"children":[]},{"data":{"text":"② 当质变来临，抓住机遇，实现质变"},"children":[]}]}]}]},{"data":{"text":"否定之否定规律"},"children":[{"data":{"text":"1. 概念"},"children":[{"data":{"text":"① 肯定因素：维持现存事物存在"},"children":[]},{"data":{"text":"② 否定因素：促使现存事物灭亡"},"children":[]}]},{"data":{"text":"2. 辩证否定观"},"children":[{"data":{"text":"① 自我否定"},"children":[]},{"data":{"text":"② 是事物发展的环节"},"children":[]},{"data":{"text":"③ 是新旧事物联系的环节"},"children":[]},{"data":{"text":"④ 实质是“扬弃”"},"children":[]},{"data":{"text":"(注：形而上学否定观：片面地肯定一切或否定一切)"},"children":[]}]},{"data":{"text":"3. 规律"},"children":[{"data":{"text":"① 事物发展不是一次否定就能完成的，需要“肯定 -> 否定 -> 否定之否定”一个周期。第一阶段问题只是初步解决，否定之否定阶段对立面的统一才根本解决"},"children":[]},{"data":{"text":"② 其中，否定之否定阶段仿佛是向原来出发点的“回复”，但这是更高阶段的“回复”"},"children":[]},{"data":{"text":"③ 总趋势：波浪式前进，螺旋式上升"},"children":[]}]},{"data":{"text":"4. 方法论"},"children":[{"data":{"text":"前进性和曲折性的统一"},"children":[]}]}]}]},{"data":{"text":"五大环节（范畴）","layout":null},"children":[{"data":{"text":" 内容与形式"},"children":[{"data":{"text":"1. 揭示了什么关系"},"children":[{"data":{"text":"构成要素（内容）和表现方式（形式）"},"children":[]}]},{"data":{"text":"2. 关系"},"children":[{"data":{"text":"① 内容决定形式"},"children":[]},{"data":{"text":"② 形式反作用于内容，具有相对独立性"},"children":[]},{"data":{"text":"③ 同一内容可由多种形式表达"},"children":[]}]},{"data":{"text":"3. 方法论"},"children":[{"data":{"text":"① 内容决定形式：重视内容，反对形式主义"},"children":[]},{"data":{"id":"djraxueoblk0","created":1783322142448,"text":"② 形式反作用内容：重视形式对内容的能动反作用"},"children":[]}]}]},{"data":{"text":"现象与本质"},"children":[{"data":{"text":"1. 揭示"},"children":[{"data":{"text":"内在联系和外在表现"},"children":[]}]},{"data":{"text":"2. 概念"},"children":[{"data":{"text":"① 本质：","expandState":"expand"},"children":[{"data":{"id":"djrb0otfjq80","created":1783322365372,"text":"内在联系、根本性质、一般的、普遍的、相对稳定的。深藏于事物内部，只能通过理性思维"},"children":[]}]},{"data":{"text":"② 现象：","expandState":"expand"},"children":[{"data":{"id":"djrb0xb8xps0","created":1783322383863,"text":"外部联系、表面特征、个别的、具体的、多变易逝。表面的、外露的，可以通过感觉器官感知"},"children":[]},{"data":{"text":"分为真象和假象"},"children":[]}]}]},{"data":{"text":"3. 关系"},"children":[{"data":{"text":"① 本质决定现象"},"children":[]},{"data":{"text":"② 现象表现本质"},"children":[]},{"data":{"text":"③ 不表现为现象的本质、不表现本质的现象都是不存在的"},"children":[]}]},{"data":{"text":"4. 方法论"},"children":[{"data":{"text":"透过现象看本质"},"children":[]}]},{"data":{"text":"5. 注意"},"children":[{"data":{"text":"不管真象还是假象，都是本质的表现"},"children":[]},{"data":{"text":"假象 ≠ 错觉"},"children":[]}]}]},{"data":{"text":" 原因与结果"},"children":[{"data":{"text":"1. 揭示"},"children":[{"data":{"text":"引起与被引起（前后相继、彼此制约）"},"children":[]}]},{"data":{"text":"2. 关系"},"children":[{"data":{"text":"① 在一个具体因果中，二者不可混淆"},"children":[]},{"data":{"text":"② 在一个因果长链中，二者相互转化"},"children":[]},{"data":{"text":"③ 不能倒果为因，也不能倒因为果"},"children":[]},{"data":{"text":"④ 没有无果之因，无因之果"},"children":[]}]},{"data":{"text":"3. 方法论"},"children":[{"data":{"text":"凡事预则立，不预则废"},"children":[]}]}]},{"data":{"text":" 必然与偶然"},"children":[{"data":{"text":"1. 揭示"},"children":[{"data":{"text":"事物发生、发展、消亡的不同趋势"},"children":[]}]},{"data":{"text":"2. 概念"},"children":[{"data":{"text":"① 必然：确定不移"},"children":[]},{"data":{"text":"② 偶然：不确定"},"children":[]}]},{"data":{"text":"3. 关系"},"children":[{"data":{"text":"① 辩证统一、不可分割、缺一不可"},"children":[]},{"data":{"text":"② 必然性伴随偶然，通过偶然来表现，并为自己开辟道路（即必然性寓于偶然之中）"},"children":[]},{"data":{"text":"③ 事物发展中，必然性起决定作用，并制约偶然"},"children":[]},{"data":{"text":"④ 在一定条件下可以相互转化"},"children":[]}]},{"data":{"text":"4. 方法论"},"children":[{"data":{"text":"① 以必然性来制定目标、计划"},"children":[]},{"data":{"text":"② 以偶然性来抓住机遇，实现目标"},"children":[]}]}]},{"data":{"text":" 可能与现实"},"children":[{"data":{"text":"1. 揭示"},"children":[{"data":{"text":"事物的过去、现在、将来的关系"},"children":[]}]},{"data":{"text":"2. 概念"},"children":[{"data":{"text":"① 可能：尚未实现的、未来的种种趋势"},"children":[]},{"data":{"text":"② 现实：已经实际存在"},"children":[]}]},{"data":{"text":"3. 关系"},"children":[{"data":{"text":"① 相互区别"},"children":[]},{"data":{"text":"② 相互转化："},"children":[{"data":{"id":"djrb1h0vbsw0","created":1783322426771,"text":"①在一定条件下 "},"children":[]},{"data":{"id":"djrb1iv5t4o0","created":1783322430780,"text":"②发展就是可能与现实相互转化的过程"},"children":[]}]}]},{"data":{"text":"4. 方法论"},"children":[{"data":{"text":"① 立足现实，对可能性进行分析"},"children":[]},{"data":{"text":"② 着眼长远，实现好的可能"},"children":[]}]}]}]},{"data":{"text":"六大思维能力","layout":null},"children":[{"data":{"text":"辩证思维能力"},"children":[{"data":{"id":"djsaz480nkw0","created":1783423802134,"text":"唯物辩证法"},"children":[]},{"data":{"id":"djsazaj40so0","created":1783423815865,"text":"辩证的逻辑思维方法","expandState":"expand"},"children":[{"data":{"text":"① 归纳与演绎（最常见）"},"children":[{"data":{"text":"归纳：从个别到一般"},"children":[]},{"data":{"text":"演绎：从一般到特别"},"children":[]}]},{"data":{"text":"② 分析与综合"},"children":[{"data":{"text":"分析：从整体到部分"},"children":[]},{"data":{"text":"综合：从部分到整体"},"children":[]}]},{"data":{"text":"③ 抽象与具体"},"children":[{"data":{"text":"具体 -> 抽象 -> 具体"},"children":[]}]},{"data":{"text":"④ 逻辑与历史"},"children":[{"data":{"id":"djsb08ijdpc0","created":1783423889841,"text":"二者统一"},"children":[]}]}]}]},{"data":{"text":"历史思维能力"},"children":[{"data":{"text":"① 历史眼光"},"children":[]},{"data":{"text":"② 发展观：方法论"},"children":[]}]},{"data":{"text":"三、 系统思维能力"},"children":[{"data":{"text":"联系观"},"children":[]}]},{"data":{"text":"四、 战略思维能力"},"children":[{"data":{"text":"整体、全局、长期"},"children":[]}]},{"data":{"text":"五、 底线思维能力"},"children":[{"data":{"text":"① “度”：关节点"},"children":[]},{"data":{"text":"② 矛盾分析法"},"children":[]}]},{"data":{"text":"六、 创新思维能力"},"children":[{"data":{"text":"守正创新"},"children":[]}]}]}]},{"data":{"text":"认识论","layout":null},"children":[{"data":{"text":"一、 认识的来源"},"children":[{"data":{"text":"1. 实践决定认识"},"children":[{"data":{"text":"实践"},"children":[{"data":{"text":"实践的概念"},"children":[{"data":{"text":"人类能动（主动、积极、创造性）改造世界的社会性的物质活动（客观性）"},"children":[{"data":{"text":"人的本质"},"children":[{"data":{"text":"一切社会关系的总和"},"children":[]}]},{"data":{"text":"人的本质属性"},"children":[{"data":{"text":"社会性"},"children":[]}]}]}]},{"data":{"text":"实践的特征"},"children":[{"data":{"text":"① 客观实在性"},"children":[{"data":{"id":"djsb29l5fkg0","created":1783424048904,"text":"把蓝图变现实"},"children":[]}]},{"data":{"text":"② 自觉能动性 / 意识的能动性"},"children":[{"data":{"id":"djsb25y0l8w0","created":1783424040975,"text":"主动积极创造性、把想象变成蓝图"},"children":[]}]},{"data":{"text":"③ 社会历史性"},"children":[{"data":{"id":"djsb2bedr6w0","created":1783424052848,"text":"受一定历史条件制约"},"children":[]}]}]},{"data":{"text":"实践的基本构成 (骨骼)"},"children":[{"data":{"text":"① 主体"},"children":[{"data":{"id":"djsb2ggweyo0","created":1783424063885,"text":"主体能力"},"children":[]},{"data":{"id":"djsb2izjdcw0","created":1783424069365,"text":"从事实践活动"},"children":[]}]},{"data":{"text":"② 客体"},"children":[{"data":{"id":"djsb2pjwmsg0","created":1783424083657,"text":"实践活动所指向的对象"},"children":[]},{"data":{"id":"djsb2qiqt8w0","created":1783424085764,"text":"客体不完全等于客观事物"},"children":[]}]},{"data":{"text":"③ 中介"},"children":[{"data":{"id":"djsb30e3jmo0","created":1783424107251,"text":"1"},"children":[{"data":{"id":"djsb33iuam00","created":1783424114068,"text":"工具手段"},"children":[]},{"data":{"id":"djsb33yz9co0","created":1783424115044,"text":"程序、方法"},"children":[]}]},{"data":{"id":"djsb315lzgw0","created":1783424108914,"text":"分类"},"children":[{"data":{"id":"djsb3gyz80o0","created":1783424143342,"text":"物质性工具系统"},"children":[]},{"data":{"id":"djsb3hgdrxk0","created":1783424144394,"text":"语言符号工具系统"},"children":[]}]}]}]},{"data":{"text":"关系","expandState":"expand"},"children":[{"data":{"text":"① 相互作用"},"children":[]},{"data":{"text":"② 实践的主客体 = 认识的主客体"},"children":[]},{"data":{"text":"③ 关系"},"children":[{"data":{"text":"实践关系（最根本）"},"children":[]},{"data":{"text":"认识和改造关系"},"children":[]},{"data":{"text":"价值关系"},"children":[]}]},{"data":{"text":"双向运动"},"children":[{"data":{"text":"主体客体化与客体主体化的双向运动（换位思考）"},"children":[]}]}]},{"data":{"text":"实践的基本形式"},"children":[{"data":{"text":"① 物质生产实践"},"children":[{"data":{"id":"djsb4fj76rs0","created":1783424218575,"text":"最基本 决定其他"},"children":[]}]},{"data":{"text":"② 社会政治实践"},"children":[]},{"data":{"text":"③ 科学文化实践"},"children":[]},{"data":{"text":"④ 关系"},"children":[{"data":{"text":"物质生产实践决定社会政治实践和科学文化实践"},"children":[]},{"data":{"text":"社会政治实践、科学文化实践又反作用于物质生产实践"},"children":[]}]},{"data":{"text":"⑤ 新的实践形式"},"children":[{"data":{"text":"虚拟实践（不是基本）"},"children":[]}]}]}]},{"data":{"tex