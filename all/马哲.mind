xt":"理性：高级阶段，抽象性、间接性，深刻，容易造成脱离现实"},"children":[]}]},{"data":{"text":"形式"},"children":[{"data":{"text":"感性"},"children":[{"data":{"text":"感觉"},"children":[]},{"data":{"text":"知觉"},"children":[]},{"data":{"text":"表象（感性认识的最高阶段）"},"children":[]}]}]},{"data":{"text":"理性"},"children":[{"data":{"text":"概念"},"children":[]},{"data":{"text":"判断"},"children":[]},{"data":{"text":"推理（理性认识的最高阶段）"},"children":[]}]},{"data":{"text":"关系"},"children":[{"data":{"text":"① 理性认识依赖于感性"},"children":[]},{"data":{"text":"② 感性有待于上升理性"},"children":[]},{"data":{"text":"③ 相互渗透"},"children":[]}]},{"data":{"text":"方法论"},"children":[{"data":{"text":"不能割裂，二者辩证统一，如果割裂就会走向","expandState":"expand"},"children":[{"data":{"text":"唯理论（夸大理性，教条主义错误）"},"children":[]},{"data":{"text":"经验论（夸大感性，经验主义错误）"},"children":[]}]}]}]},{"data":{"text":"第一次飞跃的条件"},"children":[{"data":{"text":"① 投身实践，深入调研，获得大量丰富的感性材料"},"children":[]},{"data":{"text":"② 运用抽象思维（去粗取精，去伪存真，由此及彼，由表及里），上升到理性认识"},"children":[]}]}]},{"data":{"text":"认识 -> 实践"},"children":[{"data":{"text":"第二次飞跃：理性认识 -> 实践"},"children":[]},{"data":{"text":"更为重要"},"children":[{"data":{"id":"djsb98ud81s0","created":1783424595834,"text":"认识的目的"},"children":[]},{"data":{"id":"djsb9cx5rpk0","created":1783424604710,"text":"检验标准"},"children":[]}]},{"data":{"text":"中介环节"},"children":[{"data":{"id":"djsb9ggxpq80","created":1783424612436,"text":"最后环节，理论为群众掌握"},"children":[]}]}]},{"data":{"id":"djtv3is56qo0","created":1783582129437,"text":"认识发展过程中的理性和非理性因素的作用"},"children":[{"data":{"id":"djtv555ig5s0","created":1783582256499,"text":"非理性因素"},"children":[{"data":{"id":"djtv5c7jexs0","created":1783582271859,"text":"情感、意志"},"children":[]},{"data":{"id":"djtv5gr3bjs0","created":1783582281748,"text":"不自觉、非逻辑"},"children":[]},{"data":{"id":"djtv5kthjqw0","created":1783582290600,"text":"联想、想象、猜测、直觉、顿悟、灵感","font-weight":"bold"},"children":[]}]},{"data":{"id":"djtv5w4a3wg0","created":1783582315197,"text":"作用"},"children":[{"data":{"id":"djtv5yeld340","created":1783582320175,"text":"理性因素"},"children":[{"data":{"id":"djtv61e9syo0","created":1783582326685,"text":"决定作用"},"children":[]}]},{"data":{"id":"djtv63nnuyw0","created":1783582331607,"text":"非理性因素","font-weight":"bold"},"children":[{"data":{"id":"djtv68qvguw0","created":1783582342685,"text":"激活、驱动"},"children":[]},{"data":{"id":"djtv6cdq2n40","created":1783582350597,"text":"重要作用"},"children":[{"data":{"id":"djtv6xo19p40","created":1783582396933,"text":"积极"},"children":[]},{"data":{"id":"djtv70386so0","created":1783582402205,"text":"消极","font-weight":"bold"},"children":[{"data":{"id":"djtv7lzoyns0","created":1783582449881,"text":"导致偏差、错误就是难免的"},"children":[]}]}]}]}]},{"data":{"id":"djtv85vk7540","created":1783582493166,"text":"方法论"},"children":[{"data":{"id":"djtv88pvk1c0","created":1783582499353,"text":"重视积极作用，防止消极作用"},"children":[]}]}]}]},{"data":{"text":"总过程 / 总规律"},"children":[{"data":{"id":"djtvcx6gddk0","created":1783582866055,"text":"总过程"},"children":[{"data":{"id":"djtvd0rim1s0","created":1783582873859,"text":"实践、认识、再实践、再认识，循环往复，以至无穷"},"children":[]}]},{"data":{"id":"djtvdf6upxc0","created":1783582905261,"text":"表现方式"},"children":[{"data":{"id":"djtvdi49vds0","created":1783582911635,"text":"波浪式前进、螺旋式上升"},"children":[]}]},{"data":{"id":"djtvdvztt5k0","created":1783582941841,"text":"实践与认识的统一是历史的，具体的统一"},"children":[]}]}]},{"data":{"text":"四、 认识的目的和任务"},"children":[{"data":{"text":"真理","font-weight":"bold"},"children":[{"data":{"id":"djtvgy25eeg0","created":1783583181428,"text":"概念"},"children":[{"data":{"id":"djtvhyeox280","created":1783583260550,"text":"主客观相符合"},"children":[]},{"data":{"id":"djtvicniew80","created":1783583291559,"text":"客观事物及其规律的正确反映"},"children":[]}]},{"data":{"id":"djtvh0akzq80","created":1783583186291,"text":"特征"},"children":[{"data":{"id":"djtvjiq8wao0","created":1783583383149,"text":"客观性"},"children":[{"data":{"id":"djtvn6sh9s00","created":1783583670619,"text":"是真理的本质属性"},"children":[]},{"data":{"id":"djtvndoesiw0","created":1783583685611,"text":"内容是客观的 形式是主观的"},"chil