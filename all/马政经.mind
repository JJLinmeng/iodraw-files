n":[]},{"data":{"id":"djuv9rskt9c0","created":1783684179196,"text":"造成全社会劳动生产率提高"},"children":[]}]}]}]},{"data":{"id":"djuvapu8fuw0","created":1783684253307,"text":"剩余价值的分配"},"children":[{"data":{"id":"djvo49i34880","created":1783765559746,"text":"资本家认为剩余价值是由全部预付资本（C+V）的增加额 马克思主义认为剩余价值是可变资本（V）创造的"},"children":[{"data":{"id":"djvo5rf9lw00","created":1783765677122,"text":"剩余价值有了利润的形态"},"children":[{"data":{"id":"djvo6mgq0ps0","created":1783765744690,"text":"剩余价值率m'=m/v=剩余价值/可变资本"},"children":[]},{"data":{"id":"djvo7k2ools0","created":1783765817852,"text":"利润率p'=m/（c+v）=剩余价值（利润）/全部预付资本"},"children":[]}]}]},{"data":{"id":"djvoafpkneg0","created":1783766043444,"text":"不同部分的资本家之间相互竞争，形成平均利润率，平均利润率计算的叫平均利润"},"children":[]},{"data":{"id":"djvoc7s3nqw0","created":1783766182911,"text":"不同部分资本家之间按照等量资本获得等量利润的原则瓜分剩余价值"},"children":[{"data":{"id":"djvodk48vx40","created":1783766288131,"text":"产业资本"},"children":[]},{"data":{"id":"djvodlkw7vk0","created":1783766291315,"text":"商业资本"},"children":[]},{"data":{"id":"djvodns0xk80","created":1783766296099,"text":"银行资本"},"children":[]},{"data":{"id":"djvodppkcbk0","created":1783766300304,"text":"农业资本"},"children":[]}]},{"data":{"id":"djvoeqr5hao0","created":1783766380941,"text":"剥削工人方面，不同部门的资本家有共同的阶级利益"},"children":[]},{"data":{"id":"djvogca7f600","created":1783766506170,"text":"当利润转化为平均利润，价值转化为生产价格（c+v+平均利润）"},"children":[{"data":{"id":"djvokhucy540","created":1783766831729,"text":"价值规律的表现形式发生变化"},"children":[{"data":{"id":"djvoklkatgw0","created":1783766839828,"text":"价格围绕价值波动->价格围绕生产价格波动，没有违背价值规律"},"children":[]}]}]}]}]},{"data":{"id":"djusw78yxko0","created":1783677473521,"text":"资本的相关理论"},"children":[{"data":{"id":"djvom36nuuw0","created":1783766956549,"text":"概念"},"children":[{"data":{"id":"djvon2k8i5c0","created":1783767033558,"text":"能够带来剩余价值的价值"},"children":[]}]},{"data":{"id":"djvom42cixc0","created":1783766958465,"text":"资本的本质"},"children":[{"data":{"id":"djvonw9cbew0","created":1783767098202,"text":"不是物，而是一定的生产关系"},"children"