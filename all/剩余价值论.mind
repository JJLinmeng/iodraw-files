[{"data":{"id":"djuu4bjsxag0","created":1783680930906,"text":"形式上的自由平等掩盖了事实上的剥削关系"},"children":[]}]},{"data":{"id":"djuu4steqgo0","created":1783680968492,"text":"劳动力商品的使用价值和价值"},"children":[{"data":{"id":"djuu50dsizk0","created":1783680984962,"text":"劳动力的价值（资本主义工资的本质）"},"children":[{"data":{"id":"djuu5amlw6w0","created":1783681007263,"text":"由生活必需品的价值决定的"},"children":[]},{"data":{"id":"djuu70kxl9s0","created":1783681142122,"text":"三层含义"},"children":[{"data":{"id":"djuu7rirh200","created":1783681200764,"text":"本人"},"children":[]},{"data":{"id":"djuu7sc1rlc0","created":1783681202535,"text":"家人"},"children":[]},{"data":{"id":"djuu7t4xq280","created":1783681204282,"text":"培训"},"children":[]},{"data":{"id":"djuu8fvi1c80","created":1783681253777,"text":"历史、道德"},"children":[]}]}]},{"data":{"id":"djuu6xxhoe00","created":1783681136351,"text":"劳动力使用价值"},"children":[{"data":{"id":"djuudnc5bbk0","created":1783681661842,"text":"使用价值是价值的源泉"},"children":[]},{"data":{"id":"djuue7c180w0","created":1783681705371,"text":"能创造出比劳动力价值更大的价值"},"children":[]}]}]},{"data":{"id":"djuuflo1xls0","created":1783681814937,"text":"货币转化为资本"},"children":[{"data":{"id":"djuufv608h40","created":1783681835613,"text":"资本"},"children":[{"data":{"id":"djuug9ujtvc0","created":1783681867572,"text":"能够带来剩余价值的价值"},"children":[]},{"data":{"id":"djuugho42u00","created":1783681884597,"text":"其本质不是物，而是一定的生产关系"},"children":[]}]}]}]}]},{"data":{"id":"djuuhrhz1l40","created":1783681984358,"text":"过程和方法"},"children":[{"data":{"id":"djuui5gycg80","created":1783682014771,"text":"资本主义生产过程二重性"},"children":[{"data":{"id":"djuulkzr52w0","created":1783682283652,"text":"劳动过程"},"children":[{"data":{"id":"djuulz0t61c0","created":1783682314191,"text":"产生使用价值，具体劳动（产生商品本身）"},"children":[]}]},{"data":{"id":"djuulu6o5mo0","created":1783682303662,"text":"价值增值过程"},"children":[{"data":{"id":"djuum7mx2yg0","created":1783682332942,"text":"超过劳动力价值补偿（工资）这一定点的部分"},"children":[]},{"data":{"id":"djuumve55aw0","created":1783682384654,"text":"分为"},"children":[{"data":{"id":"djuumx5noew0","created":1783682388495,"text":"必要劳动（工资）"},"children":[]},{"data":{"id":"djuun1kftnk0","created":1783682398096,"text":"剩余劳动（剩余价值）"},"children":[]}]},{"data":{"id":"djuuoaw3tdk0","created":1783682496757,"text":"剩余价值"},"children":[{"data":{"id":"djuuomwe8zk0","created":1783682522895,"text":"被剥削"},"children":[]}]}]}]},{"data":{"id":"djuuoqtpgkg0","created":1783682531440,"text":"在剩余价值产生的作用不同资本分为"},"children":[{"data":{"id":"djuupfvv9000","created":1783682585990,"text":"不变资本 C"},"children":[{"data":{"id":"djuurr2stxk0","created":1783682767082,"text":"生产资料（原材料 厂房 机器）具体劳动 转移 不增值 "},"children":[]}]},{"data":{"id":"djuupplc95k0","created":1783682607121,"text":"可变资本 V（创造剩余价值）"},"children":[{"data":{"id":"djuus1g95nk0","created":1783682789664,"text":"劳动力价值（资本主义工资） 再生产创造新价值（V+m）"},"children":[]}]},{"data":{"id":"djvnyuh2pgw0","created":1783765135212,"text":"剩余价值的源泉"},"children":[{"data":{"id":"djvnyx3n0u80","created":1783765140930,"text":"雇佣工人剩余劳动"},"children":[]}]},{"data":{"id":"djuuvnxawjs0","created":1783683073676,"text":"资本家对雇佣工人的剥削程度用剩余价值率表示"},"children":[{"data":{"id":"djuuvtat0oo0","created":1783683085377,"text":"m'=m/v=剩余价值/可变资本=剩余价值/劳动力价值（工资）=剩余劳动时间/必要劳动时间"},"children":[]}]}]},{"data":{"id":"djuuz9llmqo0","created":1783683355950,"text":"剩余价值生产的基本方法"},"children":[{"data":{"id":"djuuzto97g00","created":1783683399647,"text":"绝对剩余价值的生产"},"children":[{"data":{"id":"djuv18ce7680","created":1783683509945,"text":"必要劳动时间不变，延长工作日长度，强度"},"children":[]}]},{"data":{"id":"djuuzvhpmm80","created":1783683403604,"text":"相对剩余价值的生产"},"children":[{"data":{"id":"djuv1fbv4lc0","created":1783683525151,"text":"工作日长度不变，缩短必要劳动时间，相对延长剩余劳动时间"},"children":[]}]},{"data":{"id":"djuv6nb5mqo0","created":1783683934343,"text":"超额剩余价值"},"children":[{"data":{"id":"djuv9clluu80","created":1783684146123,"text":"差额"},"children":[]},{"data":{"id":"djuv9frt4ew0","created":1783684153028,"text":"提高劳动生产率获得"},"children":[]},{"data":{"id":"djuv9rskt9c0","created":1783684179196,"text":"造成全社会劳动生产率提高"},"children":[]}]}]}]},{"data":{"id":"djuvapu8fuw0","created":1783684253307,"text":"剩余价值的分配"},"children":[{"data":{"id":"djvo49i34880","created":1783765559746,"text":"资本家认为剩余价值是由全部预付资本（C+V）的增加额 马克思主义认为剩余价值是可变资本（V）创造的"},"children":[{"data":{"id":"djvo5rf9lw00","created":1783765677122,"text":"剩余价值有了利润的形态"},"children":[{"data":{"id":"djvo6mgq0ps0","created":1783765744690,"text":"剩余价值率m'=m/v=剩余价值/可变资本"},"children":[]},{"data":{"id":"djvo7k2ools0","created":1783765817852,"text":"利润率p'=m/（c+v）=剩余价值（利润）/全部预付资本"},"children":[]}]}]},{"data":{"id":"djvoafpkneg0","created":1783766043444,"text":"不同部分的资本家之间相互竞争，形成平均利润率，平均利润率计算的叫平均利润"},"children":[]},{"data":{"id":"djvoc7s3nqw0","created":1783766182911,"text":"不同部分资本家之间按照等量资本获得等量利润的原则瓜分剩余价值"},"children":[{"data":{"id":"djvodk48vx40","created":1783766288131,"text":"产业资本"},"children":[]},{"data":{"id":"djvodlkw7vk0","created":1783766291315,"text":"商业资本"},"children":[]},{"data":{"id":"djvodns0xk80","created":1783766296099,"text":"银行资本"},"children":[]},{"data":{"id":"djvodppkcbk0","created":1783766300304,"text":"农业资本"},"children":[]}]},{"data":{"id":"djvoeqr5hao0","created":1783766380941,"text":"剥削工人方面，不同部门的资本家有共同的阶级利益"},"children":[]},{"data":{"id":"djvogca7f600","created":1783766506170,"text":"当利润转化为平均利润，价值转化为生产价格（c+v+平均利润）"},"children":[{"data":{"id":"djvokhucy540","created":1783766831729,"text":"价值规律的表现形式发生变化"},"children":[{"data":{"id":"djvoklkatgw0","created":1783766839828,"text":"价格围绕价值波动->价格围绕生产价格波动，没有违背价值规律"},"children":[]}]}]}]}]},{"data":{"id":"djusw78yxko0","created":1783677473521,"text":"资本的相关理论"},"children":[{"data":{"id":"djvom36nuuw0","created":1783766956549,"text":"概念"},"children":[{"data":{"id":"djvon2k8i5c0","created":1783767033558,"text":"能够带来剩余价值的价值"},"children":[]}]},{"data":{"id":"djvom42cixc0","created":1783766958465,"text":"资本的本质"},"children":[{"data":{"id":"djvonw9cbew0","created":1783767098202,"text":"不是物，而是一定的生产关系"},"children":[]}]},{"data":{"id":"djvom9ssc7c0","created":1783766970948,"text":"资本的分类"},"children":[{"data":{"id":"djvoobplk0o0","created":1783767131837,"text":"根据作用不同"},"children":[{"data":{"id":"djvooleoyeg0","created":1783767152945,"text":"不变资本 C 生产资料（原材料 厂房 机器）"},"children":[]},{"data":{"id":"djvoomf3foo0","created":1783767155147,"text":"可变资本 V 劳动力"},"children":[]},{"data":{"id":"djvooti0yfk0","created":1783767170561,"text":"剩余价值率 m'"},"children":[]}]},{"data":{"id":"djvop2sl0nc0","created":1783767190791,"text":"转化形式不同"},"children":[{"data":{"id":"djvopryphww0","created":1783767245581,"text":"固定资本"},"children":[{"data":{"id":"djvoq0epfk80","created":1783767263962,"text":"厂房 机器（折旧）"},"children":[]}]},{"data":{"id":"djvopt81pdk0","created":1783767248322,"text":"流动资本"},"children":[{"data":{"id":"djvoq4uxzg00","created":1783767273651,"text":"原料 劳动力"},"children":[]}]}]}]},{"data":{"id":"djvoqq4uf6o0","created":1783767319962,"text":"资本积累","layout_left_offset":{"x":26,"y":0}},"children":[{"data":{"id":"djvoqvatm2w0","created":1783767331208,"text":"概念"},"children":[{"data":{"id":"djvotuo0yog0","created":1783767564922,"text":"剩余价值资本化"},"children":[]}]},{"data":{"id":"djvoqwwvaa00","created":1783767334717,"text":"再生产"},"children":[{"data":{"id":"djvou11u4hc0","created":1783767578817,"text":"简单再生产"},"children":[]},{"data":{"id":"djvou2q3j8w0","created":1783767582461,"text":"扩大再生产"},"children":[{"data":{"id":"djvoujph9xs0","created":1783767619429,"text":"其源泉是资本积累"},"children":[]}]}]},{"data":{"id":"djvovp3ufsg0","created":1783767709546,"text":"资本积累的源泉是剩余价值"},"children":[]},{"data":{"id":"djvowj1t2so0","created":1783767774726,"text":"资本积累的后果","layout_left_offset":{"x":0,"y":2}},"children":[{"data":{"id":"djvowsdqre00","created":1783767795039,"text":"两极分化"},"children":[]},{"data":{"id":"djvoxjny6f40","created":1783767854429,"text":"工人失业"},"children":[]}]},{"data":{"id":"djvoypui7xk0","created":1783767946250,"text":"随着资本积累而产生的工人失业是资本家为了追逐剩余价值引起资本有机构成提高而导致的"},"children":[]},{"data":{"id":"djvozj5no2o0","created":1783768010051,"text":"资本有机构成"},"children":[{"data":{"id":"djvp12bytxc0","created":1783768130156,"text":"=c/v=不变资本/可变资本=生产资料价值/劳动力价值"},"children":[]},{"data":{"id":"djvp1gl8cm00","created":1783768161191,"text":"资本技术构成"},"children":[]},{"data":{"id":"djvp1i1aiu80","created":1783768164339,"text":"资本价值构成"},"children":[]}]},{"data":{"id":"djvp5v5vtuw0","created":1783768506371,"text":"相对过剩人口"},"children":[]},{"data":{"id":"djvp74xhe6g0","created":1783768605995,"text":"自动化生产条件下，剩余价值的源泉仍然是雇佣工人的剩余劳动"},"children":[]}]},{"data":{"id":"djvp8cnv6hs0","created":1783768701192,"text":"分支主题"},"children":[]}]}]},"template":"default","theme":"fresh-blue","version":"1.4.43"}