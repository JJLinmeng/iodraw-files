{"root":{"data":{"id":"djusv5zvflk0","created":1783677392430,"text":"剩余价值论"},"children":[{"data":{"id":"djusv925o7k0","created":1783677399098,"text":"剩余价值产生的前提、过程及方法、分配"},"children":[{"data":{"id":"djuszmn0am80","created":1783677742114,"text":"资本主义生产关系"},"children":[{"data":{"id":"djuszowmlb40","created":1783677747049,"text":"两个途径"},"children":[{"data":{"id":"djuszqamejk0","created":1783677750072,"text":"小商品经济转化"},"children":[]},{"data":{"id":"djuszs2gujc0","created":1783677753933,"text":"商品高利贷转化"},"children":[]}]},{"data":{"id":"djuszvniof40","created":1783677761736,"text":"资本原始积累"},"children":[{"data":{"id":"djut04gmxzc0","created":1783677780911,"text":"暴力掠夺人民土地"},"children":[]},{"data":{"id":"djut06nkog00","created":1783677785684,"text":"暴力掠夺人民财富"},"children":[]}]},{"data":{"id":"djut0b2qma80","created":1783677795308,"text":"资本主义所有制确立"},"children":[]},{"data":{"id":"djut0d3z8sg0","created":1783677799736,"text":"对比"},"children":[{"data":{"id":"djut0edw0680","created":1783677802512,"text":"奴隶社会"},"children":[{"data":{"id":"djut0hfc5140","created":1783677809130,"text":"奴隶归奴隶主"},"children":[]}]},{"data":{"id":"djut0wd4wgw0","created":1783677841649,"text":"封建社会"},"children":[{"data":{"id":"djut0y714l40","created":1783677845633,"text":"农奴人身依附于地主"},"children":[]}]},{"data":{"id":"djut1cmdycg0","created":1783677877037,"text":"资本主义社会"},"children":[{"data":{"id":"djut1exufq80","created":1783677882083,"text":"工人有一定人身自由，失去生产资料，失去生活来源，只能出卖劳动力"},"children":[]}]}]}]},{"data":{"id":"djut2rm4ot40","created":1783677988037,"text":"前提"},"children":[{"data":{"id":"djut2svbc6o0","created":1783677990769,"text":"劳动力成为商品，货币转化为资本（形成雇佣）"},"children":[{"data":{"id":"djuu13083i00","created":1783680677216,"text":"劳动力成为商品的条件"},"children":[{"data":{"id":"djuu39ev4140","created":1783680847890,"text":"自由人 劳动力归自己所有"},"children":[]},{"data":{"id":"djuu3d6c1ds0","created":1783680856081,"text":"没有任何生产资料"},"children":[]}]},{"data":{"id":"djuu499357s0","created":1783680925905,"text":"形成雇佣"},"children":[{"data":{"id":"djuu4bjsxag0","created":1783680930906,"text":"形式上的自由平等掩盖了事实上的剥削关系"},"children":[]}]},{"data":{"id":"djuu4steqgo0","created":1783680968492,"text":"劳动力商品的使用价值和价值"},"children":[{"data":{"id":"djuu50dsizk0","created":1783680984962,"text":"劳动力的价值（资本主义工资的本质）"},"children":[{"data":{"id":"djuu5amlw6w0","created":1783681007263,"text":"由生活必需品的价值决定的"},"children":[]},{"data":{"id":"djuu70kxl9s0","created":1783681142122,"text":"三层含义"},"children":[{"data":{"id":"djuu7rirh200","created":1783681200764,"text":"本人"},"children":[]},{"data":{"id":"djuu7sc1rlc0","created":1783681202535,"text":"家人"},"children":[]},{"data":{"id":"djuu7t4xq280","created":1783681204282,"text":"培训"},"children":[]},{"data":{"id":"djuu8fvi1c80","created":1783681253777,"text":"历史、道德"},"children":[]}]}]},{"data":{"id":"djuu6xxhoe00","created":1783681136351,"text":"劳动力使用价值"},"children":[{"data":{"id":"djuudnc5bbk0","created":1783681661842,"text":"使用价值是价值的源泉"},"children":[]},{"data":{"id":"djuue7c180w0","created":1783681705371,"text":"能创造出比劳动力价值更大的价值"},"children":[]}]}]},{"data":{"id":"djuuflo1xls0","created":1783681814937,"text":"货币转化为资本"},"children":[{"data":{"id":"djuufv608h40","created":1783681835613,"text":"资本"},"children":[{"data":{"id":"djuug9ujtvc0","created":1783681867572,"text":"能够带来剩余价值的价值"},"children":[]},{"data":{"id":"djuugho42u00","created":1783681884597,"text":"其本质不是物，而是一定的生产关系"},"children":[]}]}]}]}]},{"data":{"id":"djuuhrhz1l40","created":1783681984358,"text":"过程和方法"},"children":[{"data":{"id":"djuui5gycg80","created":1783682014771,"text":"资本主义生产过程二重性"},"children":[{"data":{"id":"djuulkzr52w0","created":1783682283652,"text":"劳动过程"},"children":[{"data":{"id":"djuulz0t61c0","created":1783682314191,"text":"产生使用价值，具体劳动（产生商品本身）"},"children":[]}]},{"data":{"id":"djuulu6o5mo0","created":1783682303662,"text":"价值增值过程"},"children":[{"data":{"id":"djuum7mx2yg0","created":1783682332942,"text":"超过劳动力价值补偿（工资）这一定点的部分"},"children":[]},{"data":{"id":"djuumve55aw0","created":1783682384654,"text":"分为"},"children":[{"data":{"id":"djuumx5noew0","created":1783682388495,"text":"必要劳动（工资）"},"children":[]},{"data":{"id":"djuun1kftnk0","created":1783682398096,"text":"剩余劳动（剩余价值）"},"children":[]}]},{"data":{"id":"djuuoaw3tdk0","created":1783682496757,"text":"剩余价值"},"children":[{"data":{"id":"djuuomwe8zk0","created":1783682522895,"text":"被剥削"},"children":[]}]}]}]},{"data":{"id":"djuuoqtpgkg0","created":1783682531440,"text":"在剩余价值产生的作用不同资本分为"},"children":[{"data":{"id":"djuupfvv9000","created":1783682585990,"text":"不变资本 C"},"children":[{"data":{"id":"djuurr2stxk0","created":1783682767082,"text":"生产资料（原材料 厂房 机器）具体劳动 转移 不增值 "},"children":[]}]},{"data":{"id":"djuupplc95k0","created":1783682607121,"text":"可变资本 V（创造剩余价值）"},"children":[{"data":{"id":"djuus1g95nk0","created":1783682789664,"text":"劳动力价值（资本主义工资） 再生产创造新价值（V+m）"},"children":[]}]},{"data":{"id":"djvnyuh2pgw0","created":1783765135212,"text":"剩余价值的源泉"},"children":[{"data":{"id":"djvnyx3n0u80","created":1783765140930,"text":"雇佣工人剩余劳动"},"children":[]}]},{"data":{"id":"djuuvnxawjs0","created":1783683073676,"text":"资本家对雇佣工人的剥削程度用剩余价值率表示"},"children":[{"data":{"id":"djuuvtat0oo0","created":1783683085377,"text":"m'=m/v=剩余价值/可变资本=剩余价值/劳动力价值（工资）=剩余劳动时间/必要劳动时间"},"children":[]}]}]},{"data":{"id":"djuuz9llmqo0","created":1783683355950,"text":"剩余价值生产的基本方法"},"children":[{"data":{"id":"djuuzto97g00","created":1783683399647,"text":"绝对剩余价值的生产"},"children":[{"data":{"id":"djuv18ce7680","created":1783683509945,"text":"必要劳动时间不变，延长工作日长度，强度"},"children":[]}]},{"data":{"id":"djuuzvhpmm80","created":1783683403604,"text":"相对剩余价值的生产"},"children":[{"data":{"id":"djuv1fbv4lc0","created":1783683525151,"text":"工作日长度不变，缩短必要劳动时间，相对延长剩余劳动时间"},"children":[]}]},{"data":{"id":"djuv6nb5mqo0","created":1783683934343,"text":"超额剩余价值"},"children":[{"data":{"id":"djuv9clluu80","created":1783684146123,"text":"差额"},"children":[]},{"data":{"id":"djuv9frt4ew0","created":1783684153028,"text":"提高劳动生产率获得"},"children":[]},{"data":{"id":"djuv9rskt9c0","created":1783684179196,"text":"造成全社会劳动生产率提高"},"children":[]}]}]}]},{"data":{"id":"djuvapu8fuw0","created":1783684253307,"text":"剩余价值的分配"},"children":[{"data":{"id":"djvo49i34880","created":1783765559746,"text":"资本家认为剩余价值是由全部预付资本（C+V）的增加额 马克思主义认为剩余价值是可变资本（V）创造的"},"children":[{"data":{"id":"djvo5rf9lw00","created":1783765677122,"text":"剩余价值有了利润的形态"},"children":[{"data":{"id":"djvo6mgq0ps0","created":1783765744690,"text":"剩余价值率m'=m/v=剩余价值/可变资本"},"children":[]},{"data":{"id":"djvo7k2ools0","created":1783765817852,"text":"利润率p'=m/（c+v）=剩余价值（利润）/全部预付资本"},"children":[]}]}]},{"data":{"id":"djvoafpkneg0","created":1783766043444,"text":"不同部分的资本家之间相互竞争，形成平均利润率，平均利润率计算的叫平均利润"},"children":[]},{"data":{"id":"djvoc7s3nqw0","created":1783766182911,"text":"不同部分资本家之间按照等量资本获得等量利润的原则瓜分剩余价值"},"children":[{"data":{"id":"djvodk48vx40","created":1783766288131,"text":"产业资本"},"children":[]},{"data":{"id":"djvodlkw7vk0","created":1783766291315,"text":"商业资本"},"children":[]},{"data":{"id":"djvodns0xk80","created":1783766296099,"text":"分支主题"},"children":[]}]}]}]},{"data":{"id":"djusw78yxko0","created":1783677473521,"text":"资本的相关理论"},"children":[]}]},"template":"default","theme":"fresh-blue","version":"1.4.43"}